local function getAimPart(character)
	local preferred = character:FindFirstChild(AimPartOptions[AimPartIndex])
	if preferred then return preferred end
	return character:FindFirstChild("Head") or character:FindFirstChild("HumanoidRootPart")
end

local function isVisible(targetPart)
	if not VisibleCheck then return true end
	local origin = Camera.CFrame.Position
	local dir = targetPart.Position - origin
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist
	params.FilterDescendantsInstances = { LocalPlayer.Character }
	params.IgnoreWater = true
	local hit = workspace:Raycast(origin, dir, params)
	return (not hit) or hit.Instance:IsDescendantOf(targetPart.Parent)
end

local function getAimPoint(part)
	return part.Position + part.AssemblyLinearVelocity * Prediction
end

local function getCharacterBounds2D(character)
	local cf, size = character:GetBoundingBox()
	local half = size * 0.5
	local corners = {
		cf * Vector3.new(-half.X, -half.Y, -half.Z),
		cf * Vector3.new(-half.X, -half.Y,  half.Z),
		cf * Vector3.new(-half.X,  half.Y, -half.Z),
		cf * Vector3.new(-half.X,  half.Y,  half.Z),
		cf * Vector3.new( half.X, -half.Y, -half.Z),
		cf * Vector3.new( half.X, -half.Y,  half.Z),
		cf * Vector3.new( half.X,  half.Y, -half.Z),
		cf * Vector3.new( half.X,  half.Y,  half.Z),
	}
	local minX, minY = math.huge, math.huge
	local maxX, maxY = -math.huge, -math.huge
	local anyVisible = false
	for _, corner in ipairs(corners) do
		local point, visible = Camera:WorldToViewportPoint(corner)
		if visible then anyVisible = true end
		minX = math.min(minX, point.X)
		maxX = math.max(maxX, point.X)
		minY = math.min(minY, point.Y)
		maxY = math.max(maxY, point.Y)
	end
	if not anyVisible then return nil end
	return minX, minY, maxX, maxY
end

local function isEnemy(p)
	local myTeam    = LocalPlayer.Team
	local theirTeam = p.Team
	if myTeam == nil or theirTeam == nil then return true end
	return myTeam ~= theirTeam
end

local function healthToColor(pct)
	-- Green at 100%, yellow at 50%, red at 0%
	if pct >= 0.5 then
		local t = (pct - 0.5) * 2
		return Color3.fromRGB(
			math.floor(255 * (1 - t)),
			220,
			math.floor(60 * (1 - t))
		)
	else
		local t = pct * 2
		return Color3.fromRGB(230, math.floor(220 * t), 0)
	end
end

local function distanceColor(dist)
	local pct = 1 - math.clamp(dist / AimMaxDistance, 0, 1)
	return healthToColor(pct)
end

local function getTarget()
	local center = Camera.ViewportSize / 2
	local best, bestPlayer, bestDist = nil, nil, AimFOV
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and isAliveCharacter(p.Character) and isEnemy(p) then
			local part = getAimPart(p.Character)
			if part and isVisible(part) then
				local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
				if myRoot then
					if (part.Position - myRoot.Position).Magnitude > AimMaxDistance then continue end
				end
				local pos, vis = Camera:WorldToViewportPoint(getAimPoint(part))
				if vis then
					local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
					if dist <= bestDist then
						bestDist = dist
						best = part
						bestPlayer = p
					end
				end
			end
		end
	end
	return best, bestPlayer
end

local function getCrosshairTarget()
	local center = Camera.ViewportSize / 2
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and isAliveCharacter(p.Character) and isEnemy(p) then
			local part = getAimPart(p.Character)
			if part and isVisible(part) then
				local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
				if myRoot then
					if (part.Position - myRoot.Position).Magnitude > AimMaxDistance then continue end
				end
				local pos, vis = Camera:WorldToViewportPoint(part.Position)
				if vis then
					local dist = (Vector2.new(pos.X, pos.Y) - center).Magnitude
					if dist <= TriggerbotThreshold then return part, p end
				end
			end
		end
	end
	return nil, nil
end

