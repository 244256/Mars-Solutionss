    -- JSON encode/decode (minimal, no external deps)
    local function encodeJSON(t)
        local parts = {}
        for k, v in pairs(t) do
            local val
            if type(v) == "boolean" then val = v and "true" or "false"
            elseif type(v) == "number" then val = tostring(v)
            else val = '"' .. tostring(v) .. '"' end
            table.insert(parts, '"' .. k .. '":' .. val)
        end
        return "{" .. table.concat(parts, ",") .. "}"
    end

    local function decodeJSON(str)
        local t = {}
        for k, v in str:gmatch('"([^"]+)":([^,}]+)') do
            if v == "true" then t[k] = true
            elseif v == "false" then t[k] = false
            else local n = tonumber(v); t[k] = n ~= nil and n or v:match('"([^"]*)"') or v end
        end
        return t
    end

