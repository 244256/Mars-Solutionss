-- Heartbeat — modifiers + chams
conn(RS.Heartbeat,function()
    if Unloaded then return end
    local ch=LP.Character if ch then
        local hm=ch:FindFirstChildOfClass("Humanoid") if hm then if hm.WalkSpeed~=WS then hm.WalkSpeed=WS end if hm.JumpPower~=JP then hm.JumpPower=JP end end
        if Cam.FieldOfView~=CFOV then Cam.FieldOfView=CFOV end
        if CFMove then local hrp=ch:FindFirstChild("HumanoidRootPart") if hrp then local mv=Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W) then mv+=Cam.CFrame.LookVector end if UIS:IsKeyDown(Enum.KeyCode.S) then mv-=Cam.CFrame.LookVector end
            if UIS:IsKeyDown(Enum.KeyCode.A) then mv-=Cam.CFrame.RightVector end if UIS:IsKeyDown(Enum.KeyCode.D) then mv+=Cam.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space) then mv+=Vector3.new(0,1,0) end if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv-=Vector3.new(0,1,0) end
            if mv.Magnitude>0 then hrp.CFrame=hrp.CFrame+mv.Unit*CFSpeed*(1/60) end
        end end
    end
    if ChamsOn then for _,p in ipairs(CachedPl) do if p~=LP then updateChams(p) end end end
end)

-- Stepped — ESP + Radar (every 2 frames)
conn(RS.Stepped,function()
    if Unloaded then return end
    sFrame=(sFrame+1)%2 if sFrame~=0 then return end
    local ctr=Cam.ViewportSize/2 local ec=espCol()
    for _,p in ipairs(CachedPl) do
        if p~=LP and p.Character and alive(p.Character) and isEnemy(p) then
            local ch=p.Character local hm=ch:FindFirstChildOfClass("Humanoid") local root=ch:FindFirstChild("HumanoidRootPart") local head=ch:FindFirstChild("Head") or root
            -- Bones
            if BoneESP and hm then
                local rig=hm.RigType==Enum.HumanoidRigType.R15 and BR15 or BR6 BoneLines[p]=BoneLines[p] or {}
                for i,pr2 in ipairs(rig) do
                    local ln=BoneLines[p][i] or newLine(2) BoneLines[p][i]=ln
                    local a=ch:FindFirstChild(pr2[1]) local b=ch:FindFirstChild(pr2[2])
                    if ln and a and b then
                        local ap,av=Cam:WorldToViewportPoint(a.Position) local bp,bv=Cam:WorldToViewportPoint(b.Position)
                        ln.Color=ec ln.Visible=av and bv
                        if ln.Visible then ln.From=Vector2.new(ap.X,ap.Y) ln.To=Vector2.new(bp.X,bp.Y) end
                    elseif ln then
                        ln.Visible=false
                    end
                end
            elseif BoneLines[p] then for _,l in pairs(BoneLines[p]) do if l then l.Visible=false end end end
            -- Tracers
            if TracerESP and root then local pos,vis=Cam:WorldToViewportPoint(root.Position) TracerLines[p]=TracerLines[p] or newLine(1.4) local tr3=TracerLines[p] if tr3 then tr3.Color=ec tr3.Visible=vis if vis then tr3.From=Vector2.new(ctr.X,Cam.ViewportSize.Y) tr3.To=Vector2.new(pos.X,pos.Y) end end elseif TracerLines[p] then TracerLines[p].Visible=false end
            -- Box + HP bar
            if BoxESP and hm then
                local x1,y1,x2,y2=bounds2D(ch) BoxLines[p]=BoxLines[p] or{newLine(1.6),newLine(1.6),newLine(1.6),newLine(1.6)} local ls=BoxLines[p]
                if x1 and ls then local tl2=Vector2.new(x1,y1) local tr4=Vector2.new(x2,y1) local br2=Vector2.new(x2,y2) local bl2=Vector2.new(x1,y2) for _,l in ipairs(ls) do if l then l.Color=ec l.Visible=true end end if ls[1] then ls[1].From,ls[1].To=tl2,tr4 end if ls[2] then ls[2].From,ls[2].To=tr4,br2 end if ls[3] then ls[3].From,ls[3].To=br2,bl2 end if ls[4] then ls[4].From,ls[4].To=bl2,tl2 end
                    if HBarESP then if not HBarLines[p] then local bg2=newLine(4) local fl2=newLine(3) if bg2 then bg2.Color=rgb(20,20,20) bg2.Transparency=1 end HBarLines[p]={bg=bg2,fill=fl2} end local hb=HBarLines[p] local hp=math.clamp(hm.Health/math.max(hm.MaxHealth,1),0,1) local bx=x1-6 local bTop=Vector2.new(bx,y1) local bBot=Vector2.new(bx,y2) local bFT=Vector2.new(bx,y2-(y2-y1)*hp) local hpc=hp>.6 and rgb(60,210,110) or hp>.3 and rgb(255,195,55) or rgb(220,60,60) if hb.bg then hb.bg.From=bTop hb.bg.To=bBot hb.bg.Visible=true end if hb.fill then hb.fill.From=bFT hb.fill.To=bBot hb.fill.Color=hpc hb.fill.Visible=hp>0 end
                    else if HBarLines[p] then if HBarLines[p].bg then HBarLines[p].bg.Visible=false end if HBarLines[p].fill then HBarLines[p].fill.Visible=false end end end
                elseif ls then for _,l in pairs(ls) do if l then l.Visible=false end end end
            else if BoxLines[p] then for _,l in pairs(BoxLines[p]) do if l then l.Visible=false end end end if HBarLines[p] then if HBarLines[p].bg then HBarLines[p].bg.Visible=false end if HBarLines[p].fill then HBarLines[p].fill.Visible=false end end end
            -- Names (show through walls - only check on-screen)
            if NameESP and head then
                local hp2,_,hZ=Cam:WorldToViewportPoint(head.Position)
                NameLbls[p]=NameLbls[p] or newTxt() local nl=NameLbls[p]
                local onScr=hZ>0 and hp2.X>-50 and hp2.X<Cam.ViewportSize.X+50
                if nl then nl.Visible=onScr if onScr then nl.Text=p.DisplayName nl.Color=ec nl.Position=Vector2.new(hp2.X,hp2.Y-22) nl.Size=math.clamp(1200/math.max(hZ,1),11,18) end end
            elseif NameLbls[p] then NameLbls[p].Visible=false end
            -- Distance (show through walls - only check on-screen)
            if DistESP and root then
                local mr2=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                local dist=mr2 and math.floor((root.Position-mr2.Position).Magnitude) or 0
                local rp,_,rZ=Cam:WorldToViewportPoint(root.Position)
                DistLbls[p]=DistLbls[p] or newTxt() local dl2=DistLbls[p]
                local onScr=rZ>0 and rp.X>-50 and rp.X<Cam.ViewportSize.X+50
                if dl2 then dl2.Visible=onScr if onScr then dl2.Text=dist.."m" dl2.Color=rgb(180,180,180) dl2.Position=Vector2.new(rp.X,rp.Y+(NameESP and -38 or -22)) dl2.Size=math.clamp(1000/math.max(rZ,1),10,15) end end
            elseif DistLbls[p] then DistLbls[p].Visible=false end
        else
            if BoneLines[p] then for _,l in pairs(BoneLines[p]) do if l then l.Visible=false end end end if TracerLines[p] then TracerLines[p].Visible=false end if BoxLines[p] then for _,l in pairs(BoxLines[p]) do if l then l.Visible=false end end end if HBarLines[p] then if HBarLines[p].bg then HBarLines[p].bg.Visible=false end if HBarLines[p].fill then HBarLines[p].fill.Visible=false end end if NameLbls[p] then NameLbls[p].Visible=false end if DistLbls[p] then DistLbls[p].Visible=false end
            if ChamsInst[p] then pcall(function()ChamsInst[p]:Destroy()end) ChamsInst[p]=nil end
        end
    end
    -- Radar
    if RadarOn then local mc=LP.Character local mr3=mc and mc:FindFirstChild("HumanoidRootPart") local di=0 if mr3 then local mp=mr3.Position local cl=Cam.CFrame.LookVector local fw=Vector3.new(cl.X,0,cl.Z) if fw.Magnitude>.01 then fw=fw.Unit end local rw=Vector3.new(fw.Z,0,-fw.X) local half=RS2/2 for _,p in ipairs(CachedPl) do if p~=LP and p.Character and alive(p.Character) then local tr5=p.Character:FindFirstChild("HumanoidRootPart") if tr5 then local diff=tr5.Position-mp if diff.Magnitude<=RadarRange then di+=1 local dot=getRDot(di) local flat=Vector3.new(diff.X,0,diff.Z) local sc2=(half-6)/RadarRange dot.Position=UDim2.fromOffset(math.clamp(half+flat:Dot(rw)*sc2,6,RS2-6),math.clamp(half-flat:Dot(fw)*sc2,6,RS2-6)) dot.BackgroundColor3=isEnemy(p) and T.RE or T.RS2 dot.Visible=true end end end end end for i=di+1,#RDots do RDots[i].Visible=false end end
end)

