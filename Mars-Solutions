    end
    local function encJSON(t)
        local p={}; for k,v in pairs(t) do
            local vs = type(v)=="boolean" and (v and "true" or "false") or tostring(v)
            table.insert(p,'"'..k..'":'..vs)
        end; return "{"..table.concat(p,",").."}"
    end
    local function decJSON(s)
        local t={}
        for k,v in s:gmatch('"([^"]+)":([^,{}]+)') do
            if v=="true" then t[k]=true elseif v=="false" then t[k]=false else local n=tonumber(v); if n then t[k]=n end end
        end; return t
    end
    local folder="Mars"
    pcall(function() if makefolder then pcall(makefolder,folder) end end)
    local file=folder.."/mars_"..tostring(game.PlaceId)..".json"

