on(UIS.InputEnded,function(i)    if i.UserInputType==Enum.UserInputType.MouseButton2 then ADS=false end end)

on(RS.RenderStepped,function(dt)
    if Unloaded then return end
    RainH=(RainH+dt*0.28)%1
    local ctr=Camera.ViewportSize/2
    if AimCircle then AimCircle.Position=ctr; AimCircle.Radius=AimFOV; AimCircle.Visible=AimbotOn and not ADS end
    if AimDot    then AimDot.Position=ctr;    AimDot.Visible=AimbotOn end
    if not AimbotOn then return end
    local best,bd=nil,AimFOV
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character and isAlive(p.Character) and isEnemy(p) then
            local part=getAimPart(p.Character)
            if part then
                if AimVisChk and not rayVis(part,LP.Character) then continue end
                local myR=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                if myR and (part.Position-myR.Position).Magnitude>AimDist then continue end
                local sp,sv=Camera:WorldToViewportPoint(part.Position+part.AssemblyLinearVelocity*AimPred)
                if sv then
                    local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
                    if d<bd then bd=d; best=part end
                end
            end
        end
    end
    if not best then return end
    if AimMethodIdx==2 then
        local sp=Camera:WorldToViewportPoint(best.Position+best.AssemblyLinearVelocity*AimPred)
        local m=UIS:GetMouseLocation()
        local dx=(sp.X-ctr.X)/AimSmooth; local dy=(sp.Y-ctr.Y)/AimSmooth
        if mousemoverel then mousemoverel(dx,dy) end
    else
        Camera.CFrame=Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position,best.Position),1/AimSmooth)
    end
end)

