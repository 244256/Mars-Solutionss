local function Chk(parent,text,default,cb,ord)
    local row=newInst("Frame",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,LayoutOrder=ord or 0},parent)
    local box=newInst("Frame",{Size=UDim2.fromOffset(16,16),Position=UDim2.new(0,0,.5,0),AnchorPoint=Vector2.new(0,.5),BackgroundColor3=T.Input},row) corner(box,4)
    local bsk=stroke(box,T.TD)
    local fill=newInst("Frame",{Size=UDim2.fromOffset(0,0),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new(.5,0,.5,0),BackgroundColor3=T.Acc},box) corner(fill,3)
    local l=lbl(row,{Size=UDim2.new(1,-26,1,0),Position=UDim2.fromOffset(24,0),Text=text})
    local state=default
    local function render() if state then tw(fill,{Size=UDim2.fromOffset(10,10)},.12) tw(bsk,{Color=T.Acc},.12) tw(l,{TextColor3=T.TP},.12) else tw(fill,{Size=UDim2.fromOffset(0,0)},.12) tw(bsk,{Color=T.TD},.12) tw(l,{TextColor3=T.TS},.12) end end
    render()
    local cl=newInst("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text=""},row)
    conn(cl.MouseButton1Click,function() state=not state render() cb(state) end)
    return function(v) state=v render() end
end

local function Sld(parent,text,mn,mx,def,step,cb,ord)
    step=step or 1
    local h=newInst("Frame",{Size=UDim2.new(1,0,0,46),BackgroundTransparency=1,LayoutOrder=ord or 0},parent)
    local tr=newInst("Frame",{Size=UDim2.new(1,0,0,18),BackgroundTransparency=1},h)
    lbl(tr,{Size=UDim2.new(.6,0,1,0),Text=text})
    local vl=lbl(tr,{Size=UDim2.new(.4,0,1,0),Position=UDim2.new(.6,0,0,0),Font=Enum.Font.GothamBold,TextColor3=T.TP,TextXAlignment=Enum.TextXAlignment.Right,Text=tostring(def)})
    local track=newInst("Frame",{Position=UDim2.new(0,0,0,26),Size=UDim2.new(1,0,0,6),BackgroundColor3=T.Input},h) corner(track,99)
    local fill=newInst("Frame",{Size=UDim2.new((def-mn)/(mx-mn),0,1,0),BackgroundColor3=T.Acc},track) corner(fill,99)
    local thumb=newInst("Frame",{Size=UDim2.fromOffset(12,12),AnchorPoint=Vector2.new(.5,.5),Position=UDim2.new((def-mn)/(mx-mn),0,.5,0),BackgroundColor3=T.TP},track) corner(thumb,99)
    cb(def)
    local drag=false
    conn(track.InputBegan,function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=true end end)
    conn(UIS.InputEnded,function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false tw(thumb,{Size=UDim2.fromOffset(12,12)},.1) end end)
    conn(RS.RenderStepped,function() if Unloaded or not drag then return end tw(thumb,{Size=UDim2.fromOffset(14,14)},.08)
        local pct=math.clamp((UIS:GetMouseLocation().X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        local v=math.clamp(math.floor((mn+(mx-mn)*pct)/step+.5)*step,mn,mx) local sp2=(v-mn)/(mx-mn)
        fill.Size=UDim2.new(sp2,0,1,0) thumb.Position=UDim2.new(sp2,0,.5,0) vl.Text=tostring(v) cb(v)
    end)
    return function(v) local c=math.clamp(v,mn,mx) local p=(c-mn)/(mx-mn) fill.Size=UDim2.new(p,0,1,0) thumb.Position=UDim2.new(p,0,.5,0) vl.Text=tostring(c) cb(c) end
end

local function DD(parent,text,opts,defIdx,cb,ord)
    local con=newInst("Frame",{Size=UDim2.new(1,0,0,46),BackgroundTransparency=1,ClipsDescendants=false,LayoutOrder=ord or 0},parent)
    lbl(con,{Size=UDim2.new(1,0,0,16),Text=text})
    local btn=newInst("TextButton",{Size=UDim2.new(1,0,0,26),Position=UDim2.fromOffset(0,18),BackgroundColor3=T.Input,Font=Enum.Font.Gotham,TextSize=12,TextColor3=T.TP,TextXAlignment=Enum.TextXAlignment.Left},con) corner(btn,7) stroke(btn,T.Brd) pad(btn,10,0,0,0)
    local chev=lbl(btn,{Size=UDim2.fromOffset(20,26),Position=UDim2.new(1,-24,0,0),Font=Enum.Font.GothamBold,TextSize=11,TextColor3=T.TD,Text="▾",TextXAlignment=Enum.TextXAlignment.Center})
    local idx=defIdx btn.Text=opts[idx] cb(idx)
    local listH=#opts*28+8
    -- Parent dropdown list to SG so it always renders on top, unaffected by any ClipsDescendants
    local dl=newInst("Frame",{Size=UDim2.fromOffset(0,0),BackgroundColor3=T.Card,ClipsDescendants=true,ZIndex=200,Visible=false},SG) corner(dl,7) stroke(dl,T.Brd)
    newInst("UIListLayout",{Padding=UDim.new(0,2),SortOrder=Enum.SortOrder.LayoutOrder},dl) pad(dl,4,4,4,4)
    local open=false
    local function close() open=false tw(dl,{Size=UDim2.fromOffset(dl.AbsoluteSize.X,0)},.14) task.delay(.15,function()if not open then dl.Visible=false end end) tw(chev,{Rotation=0},.14) end
    local function reposition() local ap=btn.AbsolutePosition local as=btn.AbsoluteSize dl.Size=UDim2.fromOffset(as.X,0) dl.Position=UDim2.fromOffset(ap.X,ap.Y+as.Y+2) end
    for i,opt in ipairs(opts) do
        local item=newInst("TextButton",{LayoutOrder=i,Size=UDim2.new(1,0,0,24),BackgroundColor3=i==idx and T.BtnH or T.Btn,Font=Enum.Font.Gotham,TextSize=12,TextColor3=i==idx and T.TA or T.TS,TextXAlignment=Enum.TextXAlignment.Left,Text=opt,ZIndex=201},dl) corner(item,6) pad(item,8,0,0,0)
        conn(item.MouseEnter,function()if i~=idx then tw(item,{BackgroundColor3=T.BtnH},.1)end end)
        conn(item.MouseLeave,function()if i~=idx then tw(item,{BackgroundColor3=T.Btn},.1)end end)
        conn(item.MouseButton1Click,function()
            local prev=idx idx=i btn.Text=opt cb(i)
            for _,c in ipairs(dl:GetChildren()) do if c:IsA("TextButton") then local isNew=c.Text==opt c.TextColor3=isNew and T.TA or T.TS c.BackgroundColor3=isNew and T.BtnH or T.Btn end end
            close()
        end)
    end
    conn(btn.MouseButton1Click,function()
        open=not open
        if open then
            reposition() dl.Visible=true tw(dl,{Size=UDim2.fromOffset(btn.AbsoluteSize.X,listH)},.16) tw(chev,{Rotation=180},.16)
        else close() end
    end)
    conn(UIS.InputBegan,function(i,gp)
        if not open or gp then return end
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local m=UIS:GetMouseLocation()
                local dp=dl.AbsolutePosition local ds2=dl.AbsoluteSize
                local bp=btn.AbsolutePosition local bs=btn.AbsoluteSize
                local inDl=m.X>=dp.X and m.X<=dp.X+ds2.X and m.Y>=dp.Y and m.Y<=dp.Y+ds2.Y
                local inBtn=m.X>=bp.X and m.X<=bp.X+bs.X and m.Y>=bp.Y and m.Y<=bp.Y+bs.Y
                if not inDl and not inBtn then close() end
            end)
        end
    end)
    return {setValue=function(ni)
        if not opts[ni] then return end idx=ni btn.Text=opts[ni]
        for _,c in ipairs(dl:GetChildren()) do if c:IsA("TextButton") then local isNew=c.Text==opts[ni] c.TextColor3=isNew and T.TA or T.TS c.BackgroundColor3=isNew and T.BtnH or T.Btn end end
    end}
end

