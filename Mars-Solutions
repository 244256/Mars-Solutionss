local function Section(parent, text)
	local l = Instance.new("TextLabel", parent)
	l.Size = UDim2.new(1, 0, 0, 16)
	l.BackgroundTransparency = 1
	l.Text = text
	l.Font = Enum.Font.GothamBold
	l.TextSize = 12
	l.TextColor3 = Theme.Accent
	l.TextXAlignment = Enum.TextXAlignment.Left
end

local function Toggle(parent, text, default, callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(1, 0, 0, 32)
	b.BackgroundColor3 = Theme.Button
	b.Font = Enum.Font.Gotham
	b.TextSize = 13
	b.TextColor3 = Theme.Text
	b.BorderSizePixel = 0
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)

	local state = default
	local function render()
		b.Text = text .. " : " .. (state and "ON" or "OFF")
		b.TextColor3 = state and Theme.Online or Theme.Text
	end
	render()

	connect(b.MouseButton1Click, function()
		state = not state
		render()
		callback(state)
	end)

	return function(v) state = v; render() end
end

local function Slider(parent, text, min, max, default, callback)
	local h = Instance.new("Frame", parent)
	h.Size = UDim2.new(1, 0, 0, 50)
	h.BackgroundTransparency = 1

	local l = Instance.new("TextLabel", h)
	l.Size = UDim2.new(1, 0, 0, 18)
	l.BackgroundTransparency = 1
	l.Text = text .. ": " .. tostring(default)
	l.Font = Enum.Font.Gotham
	l.TextSize = 12
	l.TextColor3 = Theme.Text
	l.TextXAlignment = Enum.TextXAlignment.Left

	local bar = Instance.new("Frame", h)
	bar.Position = UDim2.new(0, 0, 0, 28)
	bar.Size = UDim2.new(1, 0, 0, 8)
	bar.BackgroundColor3 = Theme.Bar
	bar.BorderSizePixel = 0
	Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

	local fill = Instance.new("Frame", bar)
	fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
	fill.BackgroundColor3 = Theme.Accent
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

	callback(default)

	local dragging = false
	connect(bar.InputBegan, function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
	end)
	connect(UIS.InputEnded, function(i)
		if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
	end)
	connect(RunService.RenderStepped, function()
		if Unloaded or not dragging then return end
		local pct = math.clamp((UIS:GetMouseLocation().X - bar.AbsolutePosition.X) / bar.AbsoluteSize.X, 0, 1)
		fill.Size = UDim2.new(pct, 0, 1, 0)
		local val = math.floor(min + (max - min) * pct)
		l.Text = text .. ": " .. tostring(val)
		callback(val)
	end)
end

local function Cycle(parent, text, options, defaultIndex, callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(1, 0, 0, 32)
	b.BackgroundColor3 = Theme.Button
	b.Font = Enum.Font.Gotham
	b.TextSize = 13
	b.TextColor3 = Theme.Text
	b.BorderSizePixel = 0
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)

	local idx = defaultIndex
	local function render() b.Text = text .. " : " .. options[idx] end
	render()
	callback(idx)

	connect(b.MouseButton1Click, function()
		idx = (idx % #options) + 1
		render()
		callback(idx)
	end)
end

local function ActionButton(parent, text, callback)
	local b = Instance.new("TextButton", parent)
	b.Size = UDim2.new(1, 0, 0, 32)
	b.BackgroundColor3 = Theme.Button
	b.Text = text
	b.Font = Enum.Font.Gotham
	b.TextSize = 13
	b.TextColor3 = Theme.Text
	b.BorderSizePixel = 0
	Instance.new("UICorner", b).CornerRadius = UDim.new(0, 10)
	connect(b.MouseButton1Click, callback)
	return b
end

-- Small info row inside a card (label: value)
local function InfoRow(parent, yOffset, labelText, valueText, valueColor)
	local label = Instance.new("TextLabel", parent)
	label.Size = UDim2.new(0.45, 0, 0, 16)
	label.Position = UDim2.fromOffset(12, yOffset)
	label.BackgroundTransparency = 1
	label.Font = Enum.Font.Gotham
	label.TextSize = 11
	label.TextColor3 = Theme.SubText
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = labelText

	local value = Instance.new("TextLabel", parent)
	value.Size = UDim2.new(0.52, 0, 0, 16)
	value.Position = UDim2.new(0.46, 0, 0, yOffset)
	value.BackgroundTransparency = 1
	value.Font = Enum.Font.GothamBold
	value.TextSize = 11
	value.TextColor3 = valueColor or Theme.Text
	value.TextXAlignment = Enum.TextXAlignment.Right
	value.Text = valueText
	value.ClipsDescendants = false

	return label, value
end

