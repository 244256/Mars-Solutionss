connect(RunService.RenderStepped, function(dt)
	if Unloaded then return end

	local char = LocalPlayer.Character
	if char and char:FindFirstChildOfClass("Humanoid") then
		local hum = char:FindFirstChildOfClass("Humanoid")
		if hum.WalkSpeed ~= WalkSpeed then hum.WalkSpeed = WalkSpeed end
		if hum.JumpPower  ~= JumpPower  then hum.JumpPower  = JumpPower  end
	end
	if Camera.FieldOfView ~= CameraFOV then Camera.FieldOfView = CameraFOV end

	-- CFrame movement
	if CFrameMoveEnabled and char and char:FindFirstChild("HumanoidRootPart") then
		local hrp = char.HumanoidRootPart
		local move = Vector3.zero
		if UIS:IsKeyDown(Enum.KeyCode.W)         then move += Camera.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.S)         then move -= Camera.CFrame.LookVector end
		if UIS:IsKeyDown(Enum.KeyCode.A)         then move -= Camera.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.D)         then move += Camera.CFrame.RightVector end
		if UIS:IsKeyDown(Enum.KeyCode.Space)     then move += Vector3.new(0,1,0) * CFrameJumpSpeed end
		if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move -= Vector3.new(0,1,0) * CFrameJumpSpeed end
		if move.Magnitude > 0 then
			hrp.CFrame = hrp.CFrame + move.Unit * CFrameWalkSpeed * dt
		end
	end

	-- FOV circle
	local center = Camera.ViewportSize / 2
	FOV.Size = UDim2.fromOffset(AimFOV * 2, AimFOV * 2)
	FOV.Position = UDim2.fromOffset(center.X, center.Y)

	-- Aimbot
	local target, targetPlayer = getTarget()
	if AimbotEnabled and ADS and target then
		local aimPoint = getAimPoint(target)
		local targetCF = CFrame.new(Camera.CFrame.Position, aimPoint)
		if AimMethodOptions[AimMethodIndex] == "Mouse" then
			Camera.CFrame = targetCF
		else
			Camera.CFrame = Camera.CFrame:Lerp(targetCF, math.clamp(AimStrength / 10, 0.1, 1))
		end
	end

	-- Triggerbot
	if TriggerbotEnabled then
		local tTarget = getCrosshairTarget()
		if tTarget then
			local now = tick()
			if now - lastTriggerFire >= TriggerbotDelay then
				lastTriggerFire = now
				if typeof(mouse1click) == "function" then
					mouse1click()
				elseif typeof(mouse1press) == "function" then
					mouse1press()
					task.delay(0.06, function()
						if typeof(mouse1release) == "function" then mouse1release() end
					end)
				end
			end
		end
	end

	-- ESP loop
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= LocalPlayer and p.Character and isAliveCharacter(p.Character) and isEnemy(p) then
			local enemyChar = p.Character
			local hum  = enemyChar:FindFirstChildOfClass("Humanoid")
			local root = enemyChar:FindFirstChild("HumanoidRootPart")
			local head = enemyChar:FindFirstChild("Head")

			-- World distance from local player
			local myRoot = char and char:FindFirstChild("HumanoidRootPart")
			local worldDist = myRoot and root and (root.Position - myRoot.Position).Magnitude or 0

			-- Bone ESP
			if BoneESPEnabled and hum then
				local rig = hum.RigType == Enum.HumanoidRigType.R15 and BonesR15 or BonesR6
				BoneLines[p] = BoneLines[p] or {}
				for i, pair in ipairs(rig) do
					local a = enemyChar:FindFirstChild(pair[1])
					local b = enemyChar:FindFirstChild(pair[2])
					if a and b then
						local ap, av = Camera:WorldToViewportPoint(a.Position)
						local bp, bv = Camera:WorldToViewportPoint(b.Position)
						local line = BoneLines[p][i] or newDrawingLine(2.2)
						BoneLines[p][i] = line
						if line then
							line.Color = Theme.Accent
							if av and bv then
								line.From = Vector2.new(ap.X, ap.Y)
								line.To   = Vector2.new(bp.X, bp.Y)
								line.Visible = true
							else
								line.Visible = false
							end
						end
					end
				end
			elseif BoneLines[p] then
				for _, line in pairs(BoneLines[p]) do if line then line.Visible = false end end
			end

			-- Tracers
			if TracersEnabled and root then
				local pos, vis = Camera:WorldToViewportPoint(root.Position)
				TracerLines[p] = TracerLines[p] or newDrawingLine(1.6)
				local tr = TracerLines[p]
				if tr then
					tr.Color = Theme.Accent
					if vis then
						tr.From = Vector2.new(center.X, center.Y)
						tr.To   = Vector2.new(pos.X, pos.Y)
						tr.Visible = true
					else
						tr.Visible = false
					end
				end
			elseif TracerLines[p] then
				TracerLines[p].Visible = false
			end

			-- Box ESP
			if BoxESPEnabled and hum then
				local minX, minY, maxX, maxY = getCharacterBounds2D(enemyChar)
				BoxLines[p] = BoxLines[p] or {
					newDrawingLine(1.8), newDrawingLine(1.8),
					newDrawingLine(1.8), newDrawingLine(1.8),
				}
				local lines = BoxLines[p]
				if minX and lines then
					local tl = Vector2.new(minX, minY)
					local tr = Vector2.new(maxX, minY)
					local br = Vector2.new(maxX, maxY)
					local bl = Vector2.new(minX, maxY)
					for _, line in ipairs(lines) do
						if line then line.Color = Theme.Accent; line.Visible = true end
					end
					if lines[1] then lines[1].From, lines[1].To = tl, tr end
					if lines[2] then lines[2].From, lines[2].To = tr, br end
					if lines[3] then lines[3].From, lines[3].To = br, bl end
					if lines[4] then lines[4].From, lines[4].To = bl, tl end
				elseif lines then
					for _, line in pairs(lines) do if line then line.Visible = false end end
				end
			elseif BoxLines[p] then
				for _, line in pairs(BoxLines[p]) do if line then line.Visible = false end end
			end

			-- Name + Distance ESP
			-- Renders above the character's head with color shifting by distance
			if NameESPEnabled and head then
				local headPos, headVis = Camera:WorldToViewportPoint(head.Position)
				NameLabels[p] = NameLabels[p] or newDrawingText()
				local lbl = NameLabels[p]
				if lbl then
					if headVis then
						local distStr = string.format("[%d]", math.floor(worldDist + 0.5))
						lbl.Text = p.DisplayName .. " " .. distStr
						lbl.Color = distanceColor(worldDist)
						lbl.Position = Vector2.new(headPos.X, headPos.Y - 18)
						lbl.Center = true
						lbl.Visible = true
					else
						lbl.Visible = false
					end
				end
			elseif NameLabels[p] then
				NameLabels[p].Visible = false
			end

			-- Health Bar ESP
			-- Thin vertical bar to the left of the character bounding box
			if HealthBarESPEnabled and hum then
				local minX, minY, maxX, maxY = getCharacterBounds2D(enemyChar)
				if minX then
					local barX    = minX - 5
					local barH    = maxY - minY
					local hpPct   = math.clamp(hum.Health / math.max(hum.MaxHealth, 1), 0, 1)
					local fillH   = barH * hpPct

					-- Background bar
					HealthBarBGs[p] = HealthBarBGs[p] or newDrawingRect(true)
					local bg = HealthBarBGs[p]
					if bg then
						bg.Color = Color3.fromRGB(30, 30, 30)
						bg.Size = Vector2.new(4, barH)
						bg.Position = Vector2.new(barX - 2, minY)
						bg.Visible = true
					end

					-- Fill bar
					HealthBarFills[p] = HealthBarFills[p] or newDrawingRect(true)
					local fill = HealthBarFills[p]
					if fill then
						fill.Color = healthToColor(hpPct)
						fill.Size = Vector2.new(4, fillH)
						fill.Position = Vector2.new(barX - 2, minY + (barH - fillH))
						fill.Visible = true
					end
				else
					if HealthBarBGs[p]   then HealthBarBGs[p].Visible   = false end
					if HealthBarFills[p] then HealthBarFills[p].Visible = false end
				end
			else
				if HealthBarBGs[p]   then HealthBarBGs[p].Visible   = false end
				if HealthBarFills[p] then HealthBarFills[p].Visible = false end
			end

		else
			-- Player is not an enemy or is dead — hide all their drawings
			if BoneLines[p] then
				for _, line in pairs(BoneLines[p]) do if line then line.Visible = false end end
			end
			if TracerLines[p]    then TracerLines[p].Visible    = false end
			if BoxLines[p]       then for _, line in pairs(BoxLines[p]) do if line then line.Visible = false end end end
			if NameLabels[p]     then NameLabels[p].Visible     = false end
			if HealthBarBGs[p]   then HealthBarBGs[p].Visible   = false end
			if HealthBarFills[p] then HealthBarFills[p].Visible = false end
		end
	end

	-- Aim Target Info
	if AimTargetInfoEnabled and ADS and target and targetPlayer then
		local targetChar = targetPlayer.Character
		local targetHum  = targetChar and targetChar:FindFirstChildOfClass("Humanoid")
		local root       = targetChar and targetChar:FindFirstChild("HumanoidRootPart")

		if not root then
			TargetInfo.Visible = false
		else
			local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
			if not onScreen then
				TargetInfo.Visible = false
			else
				TargetInfo.Position = UDim2.fromOffset(
					math.clamp(screenPos.X, 120, Camera.ViewportSize.X - 120),
					math.clamp(screenPos.Y - 80, 80, Camera.ViewportSize.Y - 100)
				)
				local healthText = "Health: N/A"
				if targetHum then
					healthText = string.format("Health: %d / %d",
						math.floor(targetHum.Health + 0.5),
						math.floor(targetHum.MaxHealth + 0.5))
				end
				TargetDisplay.Text = "Display: " .. (targetPlayer.DisplayName or "Unknown")
				TargetUser.Text    = "User: @"   .. (targetPlayer.Name or "Unknown")
				TargetHealth.Text  = healthText
				TargetUserId.Text  = "ID: "      .. tostring(targetPlayer.UserId or 0)

				if not ThumbnailCache[targetPlayer.UserId] then
					local ok, img = pcall(Players.GetUserThumbnailAsync, Players,
						targetPlayer.UserId,
						Enum.ThumbnailType.HeadShot,
						Enum.ThumbnailSize.Size100x100)
					if ok and img then ThumbnailCache[targetPlayer.UserId] = img end
				end
				TargetAvatar.Image = ThumbnailCache[targetPlayer.UserId] or ""
				TargetInfo.Visible = true
			end
		end
	else
		TargetInfo.Visible = false
	end

	-- Radar
	if RadarEnabled then
		local myChar = LocalPlayer.Character
		local myRoot = myChar and myChar:FindFirstChild("HumanoidRootPart")
		local dotIndex = 0
		if myRoot then
			local myPos   = myRoot.Position
			local myYaw   = myRoot.CFrame.LookVector
			local half    = RadarSize / 2
			local forward = Vector3.new(myYaw.X, 0, myYaw.Z).Unit
			local right   = Vector3.new(forward.Z, 0, -forward.X)
			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= LocalPlayer and p.Character and isAliveCharacter(p.Character) then
					local theirRoot = p.Character:FindFirstChild("HumanoidRootPart")
					if theirRoot then
						local diff = theirRoot.Position - myPos
						if diff.Magnitude <= RadarRange then
							dotIndex = dotIndex + 1
							local dot = getRadarDot(dotIndex)
							local flatDiff = Vector3.new(diff.X, 0, diff.Z)
							local fx = flatDiff:Dot(right)
							local fy = flatDiff:Dot(forward)
							local scale = (half - 6) / RadarRange
							dot.Position = UDim2.fromOffset(
								math.clamp(half + fx * scale, 6, RadarSize - 6),
								math.clamp(half - fy * scale, 6, RadarSize - 6)
							)
							dot.BackgroundColor3 = isEnemy(p) and Theme.RadarDot or Theme.RadarSelf
							dot.Visible = true
						end
					end
				end
			end
		end
		for i = dotIndex + 1, #RadarDotPool do
			RadarDotPool[i].Visible = false
		end
	end

	-- HUD + session stats update (throttled)
	local now = tick()
	if now - lastHUDUpdate >= 0.25 then
		lastHUDUpdate = now

		table.insert(fpsBuffer, 1 / math.max(dt, 0.001))
		if #fpsBuffer > fpsBufferSize then table.remove(fpsBuffer, 1) end
		local sum = 0
		for _, v in ipairs(fpsBuffer) do sum = sum + v end
		local fps = math.floor(sum / #fpsBuffer + 0.5)

		local ping = 0
		pcall(function()
			ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue() + 0.5)
		end)

		local playerCount = #Players:GetPlayers()

		HUDFpsLabel.Text       = fps .. " FPS"
		HUDFpsLabel.TextColor3 = getFPSColor(fps)
		HUDPingLabel.Text      = ping .. "ms"
		HUDPingLabel.TextColor3 = getPingColor(ping)
		HUDPlayersLabel.Text   = playerCount .. " plrs"
		HUDName.Text = LocalPlayer.DisplayName or "..."
		HUDUser.Text = "@" .. (LocalPlayer.Name or "...")

		-- Session stats on HUD bottom row
		HUDStats.Text = "K/D: " .. getKD() .. "  T: " .. formatSessionTime()

		-- Session stats card
		SessionTimeValue.Text   = formatSessionTime()
		SessionKillsValue.Text  = tostring(SessionKills)
		SessionDeathsValue.Text = tostring(SessionDeaths)
		SessionKDValue.Text     = getKD()
		SessionFPSValue.Text    = fps .. " fps"
		SessionFPSValue.TextColor3 = getFPSColor(fps)

		-- Player fill bar in server card
		local maxP = Players.MaxPlayers
		local curP = #Players:GetPlayers()
		FillBarFill.Size = UDim2.new(math.clamp(curP / math.max(maxP, 1), 0, 1), 0, 1, 0)
		ServerPlayersValue.Text = curP .. " / " .. maxP
	end
end)

