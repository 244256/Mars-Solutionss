		Main.Position = UDim2.new(
			startPos.X.Scale, startPos.X.Offset + d.X,
			startPos.Y.Scale, startPos.Y.Offset + d.Y
		)
	end
end)

local minimized = false
local full      = Main.Size
local collapsed = UDim2.new(full.X.Scale, full.X.Offset, 0, Header.Size.Y.Offset)

connect(Minimize.MouseButton1Click, function()
	minimized = not minimized
	if minimized then
		Body.Visible = false
		tween(Main, { Size = collapsed }, 0.16)
	else
		tween(Main, { Size = full }, 0.16)
		task.delay(0.16, function()
			if not Unloaded then Body.Visible = true end
		end)
	end
end)

local function unload()
	if Unloaded then return end
	Unloaded = true
	clearAllDrawings()
	for _, c in pairs(CharacterConnections) do
		pcall(function() c:Disconnect() end)
	end
	table.clear(CharacterConnections)
	disconnectAll()
	ScreenGui:Destroy()
end

connect(Close.MouseButton1Click, unload)

task.delay(0.5, function()
	Notify("Mars Solutions", "v5 loaded. [Insert] to toggle menu.", 4)
end)
