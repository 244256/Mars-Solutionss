-- Game logic helpers
local function espCol() return RainbowOn and Color3.fromHSV(rhue,1,1) or T.Acc end
local function alive(c) if not c then return false end local h=c:FindFirstChildOfClass("Humanoid") return h and h.Health>0 end
local function isEnemy(p)
    if TeamChk then local a,b=LP.Team,p.Team if a and b then return a~=b end return false end
    return p~=LP
end
local function visChk(part,vc)
    if not vc then return true end
    local params=RaycastParams.new() params.FilterType=Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances={LP.Character} params.IgnoreWater=true
    local hit=workspace:Raycast(Cam.CFrame.Position,part.Position-Cam.CFrame.Position,params)
    return not hit or hit.Instance:IsDescendantOf(part.Parent)
end
local function aimPart(char) return char:FindFirstChild(AimParts[AimPI]) or char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart") end
local function aimPt(part) return part.Position+part.AssemblyLinearVelocity*Pred end
local function bounds2D(char)
    local ok,cf,sz=pcall(function()return char:GetBoundingBox()end) if not ok then return nil end
    local h=sz*.5 local minX,minY,maxX,maxY=math.huge,math.huge,-math.huge,-math.huge local anyV=false
    for _,c in ipairs({cf*Vector3.new(-h.X,-h.Y,-h.Z),cf*Vector3.new(-h.X,-h.Y,h.Z),cf*Vector3.new(-h.X,h.Y,-h.Z),cf*Vector3.new(-h.X,h.Y,h.Z),cf*Vector3.new(h.X,-h.Y,-h.Z),cf*Vector3.new(h.X,-h.Y,h.Z),cf*Vector3.new(h.X,h.Y,-h.Z),cf*Vector3.new(h.X,h.Y,h.Z)}) do
        local p,v=Cam:WorldToViewportPoint(c) if v then anyV=true end
        minX=math.min(minX,p.X) maxX=math.max(maxX,p.X) minY=math.min(minY,p.Y) maxY=math.max(maxY,p.Y)
    end
    if not anyV then return nil end return minX,minY,maxX,maxY
end

local function getTarget()
    local ctr=Cam.ViewportSize/2 local best,bPlr,bDst=nil,nil,AimFOV
    for _,p in ipairs(CachedPl) do
        if p~=LP and p.Character and alive(p.Character) and isEnemy(p) then
            local pt=aimPart(p.Character) if not pt then continue end
            if not visChk(pt,VisChk) then continue end
            local mr=LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
            if mr and (pt.Position-mr.Position).Magnitude>AimMaxDist then continue end
            local pos,vis=Cam:WorldToViewportPoint(aimPt(pt))
            if vis then local d=(Vector2.new(pos.X,pos.Y)-ctr).Magnitude if d<bDst then bDst=d best=pt bPlr=p end end
        end
    end return best,bPlr
end

local function applyAim(toPos,dt)
    local tgt=CFrame.new(Cam.CFrame.Position,toPos)
    local base=math.clamp((AimStrength/10)*math.clamp(dt*60,.6,1.8),.04,1)
    if AimMethods[AimMI]=="Mouse" then
        Cam.CFrame=Cam.CFrame:Lerp(tgt,math.clamp(base*.7,.03,.55))
    else
        Cam.CFrame=Cam.CFrame:Lerp(tgt,math.clamp(base,.06,.9))
    end
end

local function getCrosshairTgt()
    local ctr=Cam.ViewportSize/2
    for _,p in ipairs(CachedPl) do
        if p~=LP and p.Character and alive(p.Character) then
            if TBTeam and not isEnemy(p) then continue end
            local pt=aimPart(p.Character) if not pt then continue end
            if not visChk(pt,TBVis) then continue end
            local pos,vis=Cam:WorldToViewportPoint(pt.Position)
            if vis and (Vector2.new(pos.X,pos.Y)-ctr).Magnitude<=TBThresh then return pt,p end
        end
    end return nil,nil
end

local function getSATgt()
    local ctr=Cam.ViewportSize/2 local best,bDst=nil,SAFOV
    for _,p in ipairs(CachedPl) do
        if p~=LP and p.Character and alive(p.Character) then
            if SATeam and not isEnemy(p) then continue end
            local pt=p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
            if not pt or not visChk(pt,SAVis) then continue end
            local pos,vis=Cam:WorldToViewportPoint(pt.Position)
            if vis then local d=(Vector2.new(pos.X,pos.Y)-ctr).Magnitude if d<bDst then bDst=d best=pt end end
        end
    end return best
end

-- Silent Aim hook
local function hookSA()
    if SAHooked then return end
    local ok=pcall(function()
        local mt=getrawmetatable(game) local old=mt.__namecall SAOrig=old
        setreadonly(mt,false)
        mt.__namecall=newcclosure(function(self,...)
            local m=getnamecallmethod()
            if SAEnabled and (m=="FireServer" or m=="InvokeServer") then
                local tool=LP.Character and LP.Character:FindFirstChildOfClass("Tool")
                if tool then local tgt=getSATgt() if tgt then
                    local ocf=Cam.CFrame Cam.CFrame=CFrame.new(Cam.CFrame.Position,tgt.Position)
                    local r={old(self,...)} Cam.CFrame=ocf return table.unpack(r)
                end end
            end return old(self,...)
        end)
        setreadonly(mt,true)
    end)
    SAHooked=true logS("SA hook "..(ok and "__namecall" or "spoof"))
end
local function unhookSA()
    if not SAHooked then return end
    pcall(function() if SAOrig then local mt=getrawmetatable(game) setreadonly(mt,false) mt.__namecall=SAOrig setreadonly(mt,true) SAOrig=nil end end)
    SAHooked=false
end

-- Chams
local function updateChams(p)
    if not ChamsOn or not(p.Character and alive(p.Character) and isEnemy(p)) then
        if ChamsInst[p] then pcall(function()ChamsInst[p]:Destroy()end) ChamsInst[p]=nil end return
    end
    if not ChamsInst[p] then
        local hl=Instance.new("Highlight") hl.DepthMode=Enum.HighlightDepthMode.AlwaysOnTop hl.FillTransparency=0.55 hl.OutlineTransparency=0 ChamsInst[p]=hl
    end
    local hl=ChamsInst[p] local ec=espCol() hl.FillColor=ec hl.OutlineColor=ec hl.Adornee=p.Character if hl.Parent~=workspace then hl.Parent=workspace end
end

