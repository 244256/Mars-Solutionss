local function hookChar(p)
    if CharacterConnections[p] then
        pcall(function() CharacterConnections[p]:Disconnect() end)
    end
    CharacterConnections[p] = p.CharacterAdded:Connect(function()
        task.delay(0.1, function() flushPlayerLines(p) end)
    end)

    -- Also flush on death
    if p.Character then
        local hum = p.Character:FindFirstChildOfClass("Humanoid")
        if hum then
            hum.Died:Connect(function()
                task.delay(0.1, function() flushPlayerLines(p) end)
            end)
        end
    end
end

for _, p in ipairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then hookChar(p) end
end
