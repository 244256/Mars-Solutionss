-- ─── Shared component builders ───────────────────────────────────────────────
-- Each tab gets a scroll inside its page. All tabs use identical setup.
local function makeScroll(page)
    page.BackgroundTransparency=1
    local sf=Instance.new("ScrollingFrame",page)
    sf.Size=UDim2.new(1,0,1,0); sf.Position=UDim2.fromOffset(0,0)
    sf.BackgroundTransparency=1; sf.BorderSizePixel=0; sf.CanvasSize=UDim2.new(0,0,0,0)
    hideBar(sf)
    local lay=Instance.new("UIListLayout",sf)
    lay.Padding=UDim.new(0,8); lay.SortOrder=Enum.SortOrder.LayoutOrder
    pad(sf,8,8,6,8)
    on(lay:GetPropertyChangedSignal("AbsoluteContentSize"),function()
        sf.CanvasSize=UDim2.new(0,0,0,lay.AbsoluteContentSize.Y+14)
    end)
    return sf
end

local function Section(parent,text,order)
    local f=Instance.new("Frame",parent)
    f.Size=UDim2.new(1,0,0,20); f.BackgroundTransparency=1; f.BorderSizePixel=0
    if order then f.LayoutOrder=order end
    local ln=Instance.new("Frame",f); ln.Size=UDim2.new(1,0,0,1); ln.Position=UDim2.new(0,0,0.5,0)
    ln.BackgroundColor3=C.Sep; ln.BorderSizePixel=0
    local l=Instance.new("TextLabel",f); l.BackgroundColor3=C.BG; l.BorderSizePixel=0
    l.Font=Enum.Font.GothamBold; l.TextSize=10; l.TextColor3=C.Accent; l.Text=" "..text.." "
    l.AutomaticSize=Enum.AutomaticSize.X; l.Size=UDim2.new(0,0,1,0); l.Position=UDim2.fromOffset(8,0)
    l.TextXAlignment=Enum.TextXAlignment.Left; l.ZIndex=2
    return f
end

local function Checkbox(parent,text,default,cb,order)
    local row=Instance.new("Frame",parent)
    row.Size=UDim2.new(1,0,0,30); row.BackgroundTransparency=1; row.BorderSizePixel=0
    if order then row.LayoutOrder=order end
    local box=Instance.new("TextButton",row)
    box.Size=UDim2.fromOffset(16,16); box.Position=UDim2.new(0,0,0.5,0); box.AnchorPoint=Vector2.new(0,0.5)
    box.BackgroundColor3=C.Input; box.BorderSizePixel=0; box.Text=""; box.AutoButtonColor=false; corner(box,4)
    stroke(box,C.Border,1)
    local fill=Instance.new("Frame",box)
    fill.Size=UDim2.new(0.62,0,0.62,0); fill.Position=UDim2.new(0.5,0,0.5,0); fill.AnchorPoint=Vector2.new(0.5,0.5)
    fill.BackgroundColor3=C.Accent; fill.BorderSizePixel=0; fill.Visible=default; corner(fill,3)
    local lbl=Instance.new("TextLabel",row)
    lbl.Size=UDim2.new(1,-24,1,0); lbl.Position=UDim2.fromOffset(24,0)
    lbl.BackgroundTransparency=1; lbl.Font=Enum.Font.Gotham; lbl.TextSize=12
    lbl.TextColor3=default and C.T1 or C.T2; lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.Text=text
    local val=default
    local function set(v)
        val=v; fill.Visible=v; lbl.TextColor3=v and C.T1 or C.T2
        if v then tw(fill,{Size=UDim2.new(0.62,0,0.62,0)},0.1) end
    end
    on(box.MouseButton1Click,function() set(not val); cb(val) end)
    return {getValue=function()return val end, setValue=function(v) set(v) end}
end

local function Slider(parent,text,mn,mx,def,step,cb,order)
    local cont=Instance.new("Frame",parent)
    cont.Size=UDim2.new(1,0,0,48); cont.BackgroundTransparency=1; cont.BorderSizePixel=0
    if order then cont.LayoutOrder=order end
    local top=Instance.new("Frame",cont); top.Size=UDim2.new(1,0,0,18); top.BackgroundTransparency=1
    local lbl=Instance.new("TextLabel",top); lbl.Size=UDim2.new(0.65,0,1,0)
    lbl.BackgroundTransparency=1; lbl.Font=Enum.Font.Gotham; lbl.TextSize=12; lbl.TextColor3=C.T2
    lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.Text=text
    local vlbl=Instance.new("TextLabel",top); vlbl.Size=UDim2.new(0.35,0,1,0); vlbl.Position=UDim2.new(0.65,0,0,0)
    vlbl.BackgroundTransparency=1; vlbl.Font=Enum.Font.GothamBold; vlbl.TextSize=11; vlbl.TextColor3=C.Accent
    vlbl.TextXAlignment=Enum.TextXAlignment.Right; vlbl.Text=tostring(def)
    local track=Instance.new("Frame",cont); track.Size=UDim2.new(1,0,0,6); track.Position=UDim2.fromOffset(0,24)
    track.BackgroundColor3=C.Input; track.BorderSizePixel=0; corner(track,3)
    local pct0=(def-mn)/(mx-mn)
    local fillF=Instance.new("Frame",track); fillF.Size=UDim2.new(pct0,0,1,0)
    fillF.BackgroundColor3=C.Accent; fillF.BorderSizePixel=0; corner(fillF,3)
    local thumb=Instance.new("Frame",track); thumb.Size=UDim2.fromOffset(12,12)
    thumb.Position=UDim2.new(pct0,0,0.5,0); thumb.AnchorPoint=Vector2.new(0.5,0.5)
    thumb.BackgroundColor3=C.T1; thumb.BorderSizePixel=0; corner(thumb,6)
    cb(def)
    local dragging=false
    on(track.InputBegan,function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=true end end)
    on(UIS.InputEnded,function(i)   if i.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end end)
    on(RS.RenderStepped,function()
        if not dragging then return end
        local p=math.clamp((UIS:GetMouseLocation().X-track.AbsolutePosition.X)/track.AbsoluteSize.X,0,1)
        local raw=mn+(mx-mn)*p
        local snapped=math.clamp(math.floor(raw/step+0.5)*step,mn,mx)
        local sp=(snapped-mn)/(mx-mn)
        fillF.Size=UDim2.new(sp,0,1,0); thumb.Position=UDim2.new(sp,0,0.5,0)
        vlbl.Text=tostring(snapped); cb(snapped)
    end)
end

local function Dropdown(parent,text,opts,defIdx,cb,order)
    local cont=Instance.new("Frame",parent)
    cont.Size=UDim2.new(1,0,0,50); cont.BackgroundTransparency=1; cont.BorderSizePixel=0
    cont.ClipsDescendants=false
    if order then cont.LayoutOrder=order end
    local lbl=Instance.new("TextLabel",cont); lbl.Size=UDim2.new(1,0,0,18); lbl.BackgroundTransparency=1
    lbl.Font=Enum.Font.Gotham; lbl.TextSize=12; lbl.TextColor3=C.T2; lbl.TextXAlignment=Enum.TextXAlignment.Left; lbl.Text=text
    local btn=Instance.new("TextButton",cont); btn.Size=UDim2.new(1,0,0,28); btn.Position=UDim2.fromOffset(0,20)
    btn.BackgroundColor3=C.Input; btn.BorderSizePixel=0; btn.Text=""; btn.AutoButtonColor=false; corner(btn,7)
    stroke(btn,C.Border,1)
    -- Label inside button
    local selL=Instance.new("TextLabel",btn); selL.Size=UDim2.new(1,-28,1,0); selL.Position=UDim2.fromOffset(10,0)
    selL.BackgroundTransparency=1; selL.Font=Enum.Font.Gotham; selL.TextSize=12; selL.TextColor3=C.T1
    selL.TextXAlignment=Enum.TextXAlignment.Left; selL.TextTruncate=Enum.TextTruncate.AtEnd
    local chev=Instance.new("TextLabel",btn); chev.Size=UDim2.fromOffset(22,28); chev.Position=UDim2.new(1,-24,0,0)
    chev.BackgroundTransparency=1; chev.Font=Enum.Font.GothamBold; chev.TextSize=11; chev.TextColor3=C.T3; chev.Text="▾"
    local idx=defIdx; selL.Text=opts[idx]; cb(idx)
    local itemH=26; local listH=#opts*itemH+10
    local dList=Instance.new("Frame",Main)
    dList.BackgroundColor3=C.Card; dList.BorderSizePixel=0; dList.ClipsDescendants=true
    dList.ZIndex=50; dList.Visible=false; dList.Size=UDim2.fromOffset(0,0)
    corner(dList,8); stroke(dList,C.Border,1)
    pad(dList,4,4,4,4)
    local dLay=Instance.new("UIListLayout",dList); dLay.Padding=UDim.new(0,2); dLay.SortOrder=Enum.SortOrder.LayoutOrder
    for i,opt in ipairs(opts) do
        local item=Instance.new("TextButton",dList)
        item.LayoutOrder=i; item.Size=UDim2.new(1,0,0,itemH)
        item.BackgroundColor3=C.Btn; item.BorderSizePixel=0
        item.Font=Enum.Font.Gotham; item.TextSize=12; item.TextXAlignment=Enum.TextXAlignment.Left
        item.TextColor3=i==idx and C.TAcc or C.T2; item.Text=opt; item.ZIndex=51; corner(item,6)
        pad(item,8,4,0,0)
        on(item.MouseEnter,function() tw(item,{BackgroundColor3=C.BtnHov},0.08) end)
        on(item.MouseLeave,function() tw(item,{BackgroundColor3=C.Btn},0.08) end)
        on(item.MouseButton1Click,function()
            idx=i; selL.Text=opt; cb(i)
            for _,ch in ipairs(dList:GetChildren()) do
                if ch:IsA("TextButton") then ch.TextColor3=ch.Text==opt and C.TAcc or C.T2 end
            end
            -- close
            tw(dList,{Size=UDim2.fromOffset(dList.AbsoluteSize.X,0)},0.12)
            tw(chev,{Rotation=0},0.12)
            task.delay(0.13,function() dList.Visible=false end)
        end)
    end
    local open=false
    local function closeDD()
        open=false
        tw(dList,{Size=UDim2.fromOffset(dList.AbsoluteSize.X,0)},0.12)
        tw(chev,{Rotation=0},0.12)
        task.delay(0.13,function() dList.Visible=false end)
    end
    on(btn.MouseButton1Click,function()
        open=not open
        if open then
            local ap=btn.AbsolutePosition; local as=btn.AbsoluteSize; local mp=Main.AbsolutePosition
            dList.Size=UDim2.fromOffset(as.X,0)
            dList.Position=UDim2.fromOffset(ap.X-mp.X, ap.Y-mp.Y+as.Y+2)
            dList.Visible=true
            tw(dList,{Size=UDim2.fromOffset(as.X,listH)},0.14)
            tw(chev,{Rotation=180},0.14)
        else closeDD() end
    end)
    on(UIS.InputBegan,function(i,gp)
        if not gp and open and i.UserInputType==Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local m=UIS:GetMouseLocation()
                local dp2=dList.AbsolutePosition; local ds2=dList.AbsoluteSize
                local bp2=btn.AbsolutePosition;   local bs2=btn.AbsoluteSize
                local inD=m.X>=dp2.X and m.X<=dp2.X+ds2.X and m.Y>=dp2.Y and m.Y<=dp2.Y+ds2.Y
                local inB=m.X>=bp2.X and m.X<=bp2.X+bs2.X and m.Y>=bp2.Y and m.Y<=bp2.Y+bs2.Y
                if not inD and not inB then closeDD() end
            end)
        end
    end)
    return {setValue=function(ni)
        if opts[ni] then idx=ni; selL.Text=opts[ni]; cb(ni)
            for _,ch in ipairs(dList:GetChildren()) do
                if ch:IsA("TextButton") then ch.TextColor3=ch.Text==opts[ni] and C.TAcc or C.T2 end
            end
        end
    end}
end

-- Sub-tab bar (for Combat sub-pages)
local function SubTabs(parent,tabs,order)
    local bar=Instance.new("Frame",parent)
    bar.Size=UDim2.new(1,0,0,28); bar.BackgroundColor3=C.BG2; bar.BorderSizePixel=0
    if order then bar.LayoutOrder=order end; corner(bar,8)
    local bLay=Instance.new("UIListLayout",bar)
    bLay.FillDirection=Enum.FillDirection.Horizontal; bLay.SortOrder=Enum.SortOrder.LayoutOrder; bLay.Padding=UDim.new(0,0)
    local sUnder=Instance.new("Frame",bar)
    sUnder.Size=UDim2.fromOffset(0,2); sUnder.Position=UDim2.new(0,0,1,-2)
    sUnder.BackgroundColor3=C.Accent; sUnder.BorderSizePixel=0; sUnder.ZIndex=3; corner(sUnder,2)
    local pCont=Instance.new("Frame",parent)
    pCont.Size=UDim2.new(1,0,0,0); pCont.AutomaticSize=Enum.AutomaticSize.Y
    pCont.BackgroundTransparency=1
    if order then pCont.LayoutOrder=order+1 end
    local sBtns={}; local sPages={}
    local function switchS(name)
        for n,p in pairs(sPages) do p.Visible=n==name end
        for n,b in pairs(sBtns)  do tw(b,{TextColor3=n==name and C.T1 or C.T3},0.1) end
        local b=sBtns[name]
        tw(sUnder,{Position=UDim2.new(0,b.AbsolutePosition.X-bar.AbsolutePosition.X,1,-2),Size=UDim2.fromOffset(b.AbsoluteSize.X,2)},0.12)
    end
    for i,name in ipairs(tabs) do
        local sb=Instance.new("TextButton",bar); sb.LayoutOrder=i; sb.Size=UDim2.new(0,80,1,0)
        sb.BackgroundTransparency=1; sb.Text=name; sb.Font=Enum.Font.GothamMedium; sb.TextSize=11
        sb.TextColor3=C.T3; sb.BorderSizePixel=0; sBtns[name]=sb
        local sp=Instance.new("ScrollingFrame",pCont)
        sp.Size=UDim2.new(1,0,0,0); sp.AutomaticSize=Enum.AutomaticSize.Y
        sp.BackgroundTransparency=1; sp.Visible=false; sp.BorderSizePixel=0; hideBar(sp)
        local spl=Instance.new("UIListLayout",sp); spl.Padding=UDim.new(0,6); spl.SortOrder=Enum.SortOrder.LayoutOrder
        pad(sp,2,2,4,6)
        sPages[name]=sp
        on(sb.MouseButton1Click,function() switchS(name) end)
    end
    task.defer(function() switchS(tabs[1]) end)
    return sPages
end

