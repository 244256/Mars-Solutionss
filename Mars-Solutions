        tween(msgLbl,    { TextTransparency = 1 },       0.22)
        tween(progTrack, { BackgroundTransparency = 1 }, 0.22)
        task.delay(0.25, function()
            if card and card.Parent then card:Destroy() end
        end)
    end)
end

