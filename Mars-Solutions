--==================================================
-- Session Stats (tracked from inject time)
--==================================================

local SessionStart  = os.time()
local SessionKills  = 0
local SessionDeaths = 0
local KilledPlayers = {} -- debounce so one death = one kill

local function onEnemyDied(player)
	if KilledPlayers[player] then return end
	KilledPlayers[player] = true
	SessionKills = SessionKills + 1
	task.delay(2, function() KilledPlayers[player] = nil end)
end

local function onLocalDied()
	SessionDeaths = SessionDeaths + 1
end

local function hookCharacterDeaths(char, player)
	local hum = char:WaitForChild("Humanoid", 5)
	if not hum then return end
	if player == LocalPlayer then
		hum.Died:Connect(onLocalDied)
	else
		hum.Died:Connect(function() onEnemyDied(player) end)
	end
end

local function hookPlayer(p)
	if p.Character then
		task.spawn(hookCharacterDeaths, p.Character, p)
	end
	p.CharacterAdded:Connect(function(char)
		task.spawn(hookCharacterDeaths, char, p)
	end)
end

for _, p in ipairs(Players:GetPlayers()) do hookPlayer(p) end
Players.PlayerAdded:Connect(hookPlayer)

local function formatSessionTime()
	local elapsed = os.time() - SessionStart
	local h = math.floor(elapsed / 3600)
	local m = math.floor((elapsed % 3600) / 60)
	local s = elapsed % 60
	if h > 0 then
		return string.format("%dh %dm %ds", h, m, s)
	elseif m > 0 then
		return string.format("%dm %ds", m, s)
	else
		return string.format("%ds", s)
	end
end

local function getKD()
	if SessionDeaths == 0 then
		return SessionKills == 0 and "0.00" or tostring(SessionKills) .. ".00"
	end
	return string.format("%.2f", SessionKills / SessionDeaths)
end

local function getAccountAge()
	local days = LocalPlayer.AccountAge
	local years  = math.floor(days / 365)
	local months = math.floor((days % 365) / 30)
	if years > 0 then
		return string.format("%dy %dm", years, months)
	elseif months > 0 then
		return string.format("%dm (%dd)", months, days)
	else
		return days .. " days"
	end
end

