        statusL.TextSize = 10; statusL.TextXAlignment = Enum.TextXAlignment.Right
        statusL.TextColor3 = Theme.TextDim; statusL.Text = "inactive"

        return dot, statusL
    end

    local ncdot, ncStatus = HookRow("__namecall hook", 8)
    local tbdot, tbStatus = HookRow("triggerbot input", 30)

    -- Update hook status dynamically
    task.spawn(function()
        while not Unloaded do
            if SAHooked then
                ncdot.BackgroundColor3 = Theme.Online; ncStatus.TextColor3 = Theme.Online
                ncStatus.Text = SAOriginalNamecall and "hooked" or "spoof"
            else
