        row.TextSize = 10
        row.TextColor3 = Theme.TextDim
        row.TextXAlignment = Enum.TextXAlignment.Left
        row.Text = timeStr .. "  " .. msg
        row.TextTruncate = Enum.TextTruncate.AtEnd
        -- Trim to 40 rows
        local children = logScroll:GetChildren()
        local labels = {}
        for _, c in ipairs(children) do if c:IsA("TextLabel") then table.insert(labels, c) end end
        if #labels > 40 then labels[1]:Destroy() end
    end

    -- Expose appendLog for logSession calls to use
    -- Wrap logSession to also push to UI
    local _origLog = logSession
    logSession = function(msg)
        _origLog(msg)
        appendLog(msg)
    end

