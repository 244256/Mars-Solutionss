local function refreshClientCard()
	NameLabel.Text = "Display Name: " .. (LocalPlayer.DisplayName or "Unknown")
	UsernameLabel.Text = "Username: @" .. (LocalPlayer.Name or "Unknown")
	UserIdValue.Text = tostring(LocalPlayer.UserId or 0)
	AccountAgeValue.Text = getAccountAge()

	local teamName = "None"
	local teamColor = Theme.SubText
	if LocalPlayer.Team then
		teamName = LocalPlayer.Team.Name
		local tc = LocalPlayer.Team.TeamColor.Color
		teamColor = tc
	end
	TeamValue.Text = teamName
	TeamValue.TextColor3 = teamColor

	local connected = isClientConnected()
	StatusDot.BackgroundColor3 = connected and Theme.Online or Theme.Offline
	StatusLabel.TextColor3     = connected and Theme.Online or Theme.Offline
	StatusLabel.Text = connected and "● Connected" or "● Offline"

	local ok, content = pcall(function()
		return Players:GetUserThumbnailAsync(LocalPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
	end)
	if ok and content then Avatar.Image = content end

	local experienceName = game.Name or "Unknown"
	local infoOk, info = pcall(function()
		return MarketplaceService:GetProductInfo(game.PlaceId)
	end)
	if infoOk and info and info.Name then experienceName = info.Name end
	ExperienceValue.Text = experienceName

	PlaceIdValue.Text = tostring(game.PlaceId)
	local shortJob = tostring(game.JobId or "N/A")
	if #shortJob > 20 then shortJob = string.sub(shortJob, 1, 20) .. "..." end
	ServerIdValue.Text = shortJob

	-- Server info
	local maxPlayers = Players.MaxPlayers
	local curPlayers = #Players:GetPlayers()
	ServerPlayersValue.Text = curPlayers .. " / " .. maxPlayers
	local fillPct = math.clamp(curPlayers / math.max(maxPlayers, 1), 0, 1)
	FillBarFill.Size = UDim2.new(fillPct, 0, 1, 0)

	local serverAge = os.time() - serverStartTime
	local sm = math.floor(serverAge / 60)
	local ss = serverAge % 60
	ServerAgeValue.Text = sm > 0 and (sm .. "m " .. ss .. "s") or (ss .. "s")

	local ping = 0
	pcall(function()
		ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue() + 0.5)
	end)
	ServerPingValue.Text = ping .. "ms"
	ServerPingValue.TextColor3 = getPingColor(ping)

	refreshPlayersList()
end

