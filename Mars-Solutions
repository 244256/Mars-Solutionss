local function connect(signal, fn)
    local c = signal:Connect(fn)
    table.insert(Connections, c)
    return c
end

local function tween(obj, props, t, style, dir)
    TweenService:Create(obj,
        TweenInfo.new(t or 0.14, style or Enum.EasingStyle.Quad, dir or Enum.EasingDirection.Out),
        props):Play()
end

local function disconnectAll()
    for _, c in ipairs(Connections) do pcall(function() c:Disconnect() end) end
    table.clear(Connections)
end

local function clearAllDrawings()
    for _, lines in pairs(BoneLines) do
        for _, l in pairs(lines) do pcall(function() l:Remove() end) end
    end
    for _, l in pairs(TracerLines) do pcall(function() l:Remove() end) end
    for _, lines in pairs(BoxLines) do
        for _, l in pairs(lines) do pcall(function() l:Remove() end) end
    end
    for _, hb in pairs(HealthBarLines) do
        pcall(function() hb.bg:Remove() end)
        pcall(function() hb.fill:Remove() end)
    end
    BoneLines = {} TracerLines = {} BoxLines = {} HealthBarLines = {}
end

local function flushPlayerLines(p)
    if BoneLines[p] then
        for _, l in pairs(BoneLines[p]) do pcall(function() l:Remove() end) end
        BoneLines[p] = nil
    end
    if TracerLines[p] then
        pcall(function() TracerLines[p]:Remove() end)
        TracerLines[p] = nil
    end
    if BoxLines[p] then
        for _, l in pairs(BoxLines[p]) do pcall(function() l:Remove() end) end
        BoxLines[p] = nil
    end
    if HealthBarLines[p] then
        pcall(function() HealthBarLines[p].bg:Remove() end)
        pcall(function() HealthBarLines[p].fill:Remove() end)
        HealthBarLines[p] = nil
    end
end

-- Rainbow: returns current hue-cycled color, or Theme.Accent if rainbow off
local function espColor()
    if RainbowEnabled then
        return Color3.fromHSV(rainbowHue, 1, 1)
    end
    return Theme.Accent
end

local function isAlive(char)
    if not char then return false end
    local h = char:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

local function isEnemy(p)
    if TeamCheck then
        local a, b = LocalPlayer.Team, p.Team
        if a and b then return a ~= b end
    end
    return p ~= LocalPlayer
end

local function newLine(thickness)
    if not Drawing then return nil end
    local l = Drawing.new("Line")
    l.Color = Theme.Accent
    l.Thickness = thickness
    l.Transparency = 1
    l.Visible = false
    return l
end

local function getAimPart(char)
    return char:FindFirstChild(AimPartOptions[AimPartIndex])
        or char:FindFirstChild("Head")
        or char:FindFirstChild("HumanoidRootPart")
end

local function isVisible(part)
    if not VisibleCheck then return true end
    local origin = Camera.CFrame.Position
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = { LocalPlayer.Character }
    params.IgnoreWater = true
    local hit = workspace:Raycast(origin, part.Position - origin, params)
    return (not hit) or hit.Instance:IsDescendantOf(part.Parent)
end

local function getAimPoint(part)
    return part.Position + part.AssemblyLinearVelocity * Prediction
end

local function getCharacterBounds2D(char)
    local cf, size = char:GetBoundingBox()
    local h = size * 0.5
    local corners = {
        cf * Vector3.new(-h.X,-h.Y,-h.Z), cf * Vector3.new(-h.X,-h.Y, h.Z),
        cf * Vector3.new(-h.X, h.Y,-h.Z), cf * Vector3.new(-h.X, h.Y, h.Z),
        cf * Vector3.new( h.X,-h.Y,-h.Z), cf * Vector3.new( h.X,-h.Y, h.Z),
        cf * Vector3.new( h.X, h.Y,-h.Z), cf * Vector3.new( h.X, h.Y, h.Z),
    }
    local minX, minY, maxX, maxY = math.huge, math.huge, -math.huge, -math.huge
    local anyVis = false
    for _, c in ipairs(corners) do
        local p, v = Camera:WorldToViewportPoint(c)
        if v then anyVis = true end
        minX = math.min(minX, p.X); maxX = math.max(maxX, p.X)
        minY = math.min(minY, p.Y); maxY = math.max(maxY, p.Y)
    end
    if not anyVis then return nil end
    return minX, minY, maxX, maxY
end

local function getTarget()
    local center = Camera.ViewportSize / 2
    local best, bestPlayer, bestDist = nil, nil, AimFOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and isAlive(p.Character) and isEnemy(p) then
            local part = getAimPart(p.Character)
            if part and isVisible(part) then
                local myRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if myRoot and (part.Position - myRoot.Position).Magnitude > AimMaxDistance then continue end
                local pos, vis = Camera:WorldToViewportPoint(getAimPoint(part))
                if vis then
                    local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if d < bestDist then bestDist = d; best = part; bestPlayer = p end
                end
            end
        end
    end
    return best, bestPlayer
end

local function getCrosshairTarget()
    local center = Camera.ViewportSize / 2
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and isAlive(p.Character) then
            if TriggerbotTeamCheck and not isEnemy(p) then continue end
            local part = getAimPart(p.Character)
            if part then
                if TriggerbotVisCheck then
                    local params = RaycastParams.new()
                    params.FilterType = Enum.RaycastFilterType.Blacklist
                    params.FilterDescendantsInstances = { LocalPlayer.Character }
                    local hit = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, params)
                    if hit and not hit.Instance:IsDescendantOf(p.Character) then continue end
                end
                local pos, vis = Camera:WorldToViewportPoint(part.Position)
                if vis and (Vector2.new(pos.X, pos.Y) - center).Magnitude <= TriggerbotThreshold then
                    return part, p
                end
            end
        end
    end
    return nil, nil
end

-- Silent Aim target picker (separate FOV + optional checks)
local function getSilentTarget()
    local center = Camera.ViewportSize / 2
    local best, bestDist = nil, SilentAimFOV
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and isAlive(p.Character) then
            if SilentTeamCheck and not isEnemy(p) then continue end
            local part = p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if SilentVisCheck then
                    local params = RaycastParams.new()
                    params.FilterType = Enum.RaycastFilterType.Blacklist
                    params.FilterDescendantsInstances = { LocalPlayer.Character }
                    local hit = workspace:Raycast(Camera.CFrame.Position, part.Position - Camera.CFrame.Position, params)
                    if hit and not hit.Instance:IsDescendantOf(p.Character) then continue end
                end
                local pos, vis = Camera:WorldToViewportPoint(part.Position)
                if vis then
                    local d = (Vector2.new(pos.X, pos.Y) - center).Magnitude
                    if d < bestDist then bestDist = d; best = part end
                end
            end
        end
    end
    return best
end

--==================================================
-- Silent Aim  —  __namecall hook
-- Works on low-UNC executors: hooks WorldToScreenPoint
-- on the Camera metatable to redirect bullet origin.
-- Falls back to a pure camera-space spoof if namecall
-- is unavailable.
--==================================================

local function hookSilentAim()
    if SAHooked then return end

    -- Method 1: __namecall metatable hook (best, most executors)
    local ok = pcall(function()
        local mt = getrawmetatable(game)
        local oldNamecall = mt.__namecall
        SAOriginalNamecall = oldNamecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local method = getnamecallmethod()
            -- Intercept FireServer / InvokeServer on RemoteEvent/RemoteFunction
            -- Redirect WorldToScreenPoint so the server thinks we aimed at target
            if SilentAimEnabled and (method == "FireServer" or method == "InvokeServer") then
                local target = getSilentTarget()
                if target then
                    -- Temporarily snap camera toward target for this call only
                    local oldCF = Camera.CFrame
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, target.Position)
                    local result = { oldNamecall(self, ...) }
                    Camera.CFrame = oldCF
                    return table.unpack(result)
                end
            end
            return oldNamecall(self, ...)
        end)
        setreadonly(mt, true)
    end)

    if ok then
        SAHooked = true
        logSession("Silent Aim: __namecall hook active")
        return
    end

    -- Method 2: Camera WorldToScreenPoint spoof (lower UNC fallback)
    -- On each RenderStepped while silent aim is on, we nudge Camera.CFrame
    -- toward the target for exactly one frame so raycasts originate there.
    -- This is the safest low-UNC approach.
    SAHooked = true
    logSession("Silent Aim: camera-spoof mode (low UNC)")
end

local function unhookSilentAim()
    if not SAHooked then return end
    pcall(function()
        if SAOriginalNamecall then
            local mt = getrawmetatable(game)
            setreadonly(mt, false)
            mt.__namecall = SAOriginalNamecall
            setreadonly(mt, true)
            SAOriginalNamecall = nil
        end
    end)
    SAHooked = false
end

