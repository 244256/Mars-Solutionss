local function CreatePage(name)
	local page = Instance.new("ScrollingFrame", Pages)
	page.Size = UDim2.new(1, 0, 1, 0)
	page.BackgroundTransparency = 1
	page.Visible = false
	page.ScrollBarThickness = 2
	page.CanvasSize = UDim2.new(0, 0, 0, 0)
	page.BorderSizePixel = 0
	local layout = Instance.new("UIListLayout", page)
	layout.Padding = UDim.new(0, 10)
	local pad = Instance.new("UIPadding", page)
	pad.PaddingTop = UDim.new(0, 2)
	connect(layout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
		page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 8)
	end)
	TabPages[name] = page
	return page
end

local function SwitchTab(name)
	for _, b in pairs(TabButtons) do
		b.stroke.Transparency = 1
		b.frame.BackgroundColor3 = Theme.Panel
	end
	for _, p in pairs(TabPages) do p.Visible = false end
	TabButtons[name].stroke.Transparency = 0
	TabButtons[name].frame.BackgroundColor3 = Theme.Button
	TabPages[name].Visible = true
end

local function MakeTab(name, x)
	local frame = Instance.new("Frame", Tabs)
	frame.Size = UDim2.new(0, 78, 0, 28)
	frame.Position = UDim2.new(0, x, 0, 2)
	frame.BackgroundColor3 = Theme.Panel
	frame.BorderSizePixel = 0
	Instance.new("UICorner", frame).CornerRadius = UDim.new(1, 0)

	local stroke = Instance.new("UIStroke", frame)
	stroke.Color = Theme.Accent
	stroke.Transparency = 1

	local label = Instance.new("TextLabel", frame)
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.Text = name
	label.Font = Enum.Font.GothamMedium
	label.TextSize = 12
	label.TextColor3 = Theme.Text

	local click = Instance.new("TextButton", frame)
	click.Size = UDim2.new(1, 0, 1, 0)
	click.BackgroundTransparency = 1
	click.Text = ""
	connect(click.MouseButton1Click, function() SwitchTab(name) end)

	TabButtons[name] = { frame = frame, stroke = stroke }
	CreatePage(name)
end

