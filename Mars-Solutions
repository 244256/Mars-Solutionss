    btn.BorderSizePixel    = 0

    TabButtons[name] = btn
    CreatePage(name)

    connect(btn.MouseButton1Click, function()
        -- Underline relative to TabBarRow
        tween(TabUnderline, {
            Position = UDim2.new(0, btn.AbsolutePosition.X - TabBarRow.AbsolutePosition.X, 1, -2),
            Size     = UDim2.fromOffset(btn.AbsoluteSize.X, 2)
        }, 0.16)
        for n, b in pairs(TabButtons) do
            tween(b, { TextColor3 = n == name and Theme.TextPrimary or Theme.TextDim }, 0.16)
        end
        for n, p in pairs(TabPages) do p.Visible = n == name end
        activeTab = name
    end)
end

