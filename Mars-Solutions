-- ─── Tab system ──────────────────────────────────────────────────────────────
local TabBtns  = {}
local TabPages = {}
local curTab   = ""

local function switchTab(name)
    for n,p in pairs(TabPages) do p.Visible = n==name end
    for n,b in pairs(TabBtns)  do tw(b,{TextColor3 = n==name and C.T1 or C.T3},0.12) end
    local b = TabBtns[name]
    tw(TBUnder,{
        Position=UDim2.new(0,b.AbsolutePosition.X-TBRow.AbsolutePosition.X,1,-2),
        Size=UDim2.fromOffset(b.AbsoluteSize.X,2)
    },0.14)
    curTab = name
end

local function MakeTab(name,order)
    local page=Instance.new("Frame",PageBox)
    page.Size=UDim2.new(1,0,1,0); page.BackgroundTransparency=1; page.Visible=false; page.BorderSizePixel=0
    TabPages[name]=page
    local btn=Instance.new("TextButton",TBHolder)
    btn.LayoutOrder=order; btn.Size=UDim2.new(0,64,1,-6)
    btn.BackgroundTransparency=1; btn.Text=name
    btn.Font=Enum.Font.GothamMedium; btn.TextSize=11; btn.TextColor3=C.T3; btn.BorderSizePixel=0
    TabBtns[name]=btn
    on(btn.MouseButton1Click,function() switchTab(name) end)
end

