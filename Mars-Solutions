-- RenderStepped  →  Camera / Aimbot only
--==================================================

connect(RunService.RenderStepped, function(dt)
    if Unloaded then return end

    -- Rainbow hue cycle (full cycle ~5 seconds)
    rainbowHue = (rainbowHue + dt * 0.2) % 1

    -- Apply rainbow to FOV circle live
    FOVStroke.Color = RainbowEnabled and Color3.fromHSV(rainbowHue, 1, 1) or Theme.Accent

    local center = Camera.ViewportSize / 2

    -- FOV circle + dot positioning
    FOVCircle.Size     = UDim2.fromOffset(AimFOV * 2, AimFOV * 2)
    FOVCircle.Position = UDim2.fromOffset(center.X, center.Y)
    FOVDot.Position    = UDim2.fromOffset(center.X, center.Y)

    -- Silent Aim camera-spoof (low UNC fallback mode)
    -- When namecall hook isn't available, briefly snap camera so server-side
    -- raycasts originate at target on the frame the player fires
    if SilentAimEnabled and SAHooked and not SAOriginalNamecall then
        local silTarget = getSilentTarget()
        if silTarget and ADS then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, silTarget.Position)
        end
    end

    -- Aimbot
    local target, targetPlayer = getTarget()

    if AimbotEnabled and ADS and target then
        local aimPoint = getAimPoint(target)
        local targetCF = CFrame.new(Camera.CFrame.Position, aimPoint)
        if AimMethodOptions[AimMethodIndex] == "Mouse" then
            Camera.CFrame = targetCF
        else
            Camera.CFrame = Camera.CFrame:Lerp(targetCF, math.clamp((11 - AimStrength) / 10, 0.08, 0.95))
        end
        -- Pulse FOV circle when target acquired
        tween(FOVStroke, { Transparency = 0.15 }, 0.06)
        task.delay(0.06, function()
            if not Unloaded then tween(FOVStroke, { Transparency = 0.4 }, 0.1) end
        end)
    end

    -- Triggerbot — multi-fallback input simulation
    if TriggerbotEnabled then
        local tTgt, _ = getCrosshairTarget()
        if tTgt then
            local now = tick()
            if now - lastTriggerFire >= TriggerbotDelay then
                lastTriggerFire = now
                -- Try every known executor input method in order
                if typeof(mouse1click) == "function" then
                    pcall(mouse1click)
                elseif typeof(mouse1press) == "function" then
                    pcall(mouse1press)
                    task.delay(math.max(0.04, TriggerbotDelay * 0.5), function()
                        pcall(function()
                            if typeof(mouse1release) == "function" then mouse1release() end
                        end)
                    end)
                end
            end
        end
    end
    -- Target Info Card
    if AimTargetInfoEnabled and ADS and target and targetPlayer then
        local tChar = targetPlayer.Character
        local tHum  = tChar and tChar:FindFirstChildOfClass("Humanoid")
        local tRoot = tChar and tChar:FindFirstChild("HumanoidRootPart")
        if tRoot then
            local sp, onScreen = Camera:WorldToViewportPoint(tRoot.Position)
            if onScreen then
                TargetInfo.Position = UDim2.fromOffset(
                    math.clamp(sp.X, 120, Camera.ViewportSize.X - 120),
                    math.clamp(sp.Y - 88, 80, Camera.ViewportSize.Y - 100))
                TIDisplay.Text = targetPlayer.DisplayName or "Unknown"
                TIUser.Text    = "@" .. (targetPlayer.Name or "Unknown")
                TIHealth.Text  = tHum and string.format("HP  %d / %d",
                    math.floor(tHum.Health + 0.5), math.floor(tHum.MaxHealth + 0.5)) or "HP  N/A"
                TIId.Text      = "ID: " .. tostring(targetPlayer.UserId)
                if not ThumbnailCache[targetPlayer.UserId] then
                    task.spawn(function()
                        local ok, img = pcall(Players.GetUserThumbnailAsync, Players,
                            targetPlayer.UserId, Enum.ThumbnailType.HeadShot, Enum.ThumbnailSize.Size100x100)
                        if ok and img then ThumbnailCache[targetPlayer.UserId] = img end
                    end)
                end
                TIAvatar.Image = ThumbnailCache[targetPlayer.UserId] or ""
                TargetInfo.Visible = true
            else
                TargetInfo.Visible = false
            end
        else
            TargetInfo.Visible = false
        end
    else
        TargetInfo.Visible = false
    end

    -- HUD update (throttled)
    local now = tick()
    if now - lastHudUpdate >= 0.25 then
        lastHudUpdate = now
        table.insert(fpsBuffer, 1 / math.max(dt, 0.001))
        if #fpsBuffer > fpsBufferSize then table.remove(fpsBuffer, 1) end
        local sum = 0; for _, v in ipairs(fpsBuffer) do sum += v end
        local fps = math.floor(sum / #fpsBuffer + 0.5)

        local ping = 0
        pcall(function() ping = math.floor(Stats.Network.ServerStatsItem["Data Ping"]:GetValue() + 0.5) end)

        local pCount = #Players:GetPlayers()
        local fpsColor = fps >= 55 and Theme.HUDGood or fps >= 30 and Theme.HUDWarn or Theme.HUDBad
        local pingColor = ping <= 80 and Theme.HUDGood or ping <= 150 and Theme.HUDWarn or Theme.HUDBad

        HUDFps.Text = fps .. " FPS";    HUDFps.TextColor3  = fpsColor
        HUDPing.Text = ping .. "ms";    HUDPing.TextColor3 = pingColor
        HUDPlrs.Text = pCount .. " plrs"
        HUDName.Text = LocalPlayer.DisplayName or "..."
        HUDUser.Text = "@" .. (LocalPlayer.Name or "...")
        HUDStats.Text = fps .. " fps  " .. ping .. "ms  " .. pCount .. " plrs"

        FooterLeft.Text = "● " .. pCount .. " players online"
    end
end)

