-- ─── Helpers ─────────────────────────────────────────────────────────────────
local function C3(r,g,b) return Color3.fromRGB(r,g,b) end
local function on(sig, fn) local c = sig:Connect(fn); table.insert(Conns,c); return c end
local function tw(obj,props,t) TweenSvc:Create(obj,TweenInfo.new(t or 0.14,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),props):Play() end
local function corner(obj,r) Instance.new("UICorner",obj).CornerRadius=UDim.new(0,r or 8) end
local function stroke(obj,col,thick) local s=Instance.new("UIStroke",obj); s.Color=col; s.Thickness=thick or 1; return s end
local function pad(obj,l,r,t,b) local p=Instance.new("UIPadding",obj); p.PaddingLeft=UDim.new(0,l); p.PaddingRight=UDim.new(0,r or l); p.PaddingTop=UDim.new(0,t or l); p.PaddingBottom=UDim.new(0,b or t or l) end
local function hideBar(sf) sf.ScrollBarImageTransparency=1; sf.ScrollBarThickness=0 end

local function isAlive(char)
    if not char then return false end
    local h = char:FindFirstChildOfClass("Humanoid")
    return h ~= nil and h.Health > 0
end
local function isEnemy(p)
    if AimTeamChk then
        local a,b = LP.Team, p.Team
        if a and b then return a ~= b end
    end
    return true
end
local function getAimPart(char)
    return char:FindFirstChild(AimParts[AimPartIdx])
        or char:FindFirstChild("Head")
        or char:FindFirstChild("HumanoidRootPart")
end
local function rayVis(part, myChar)
    local params = RaycastParams.new()
    params.FilterType = Enum.RaycastFilterType.Blacklist
    params.FilterDescendantsInstances = {myChar}
    params.IgnoreWater = true
    local dir = part.Position - Camera.CFrame.Position
    local hit = workspace:Raycast(Camera.CFrame.Position, dir, params)
    return not hit or hit.Instance:IsDescendantOf(part.Parent)
end

