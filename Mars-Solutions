connect(RunService.Heartbeat, function()
    if Unloaded then return end
    local char = LocalPlayer.Character
    if char then
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then
            if hum.WalkSpeed ~= WalkSpeed then hum.WalkSpeed = WalkSpeed end
            if hum.JumpPower  ~= JumpPower  then hum.JumpPower  = JumpPower  end
            -- Inf jump: re-enable jump every frame
            if InfJumpEnabled then
                hum:SetAttribute("_marsJump", true)
                if hum.FloorMaterial ~= Enum.Material.Air then
                    -- grounded, reset so next space press works
                elseif UIS:IsKeyDown(Enum.KeyCode.Space) then
                    hum:ChangeState(Enum.HumanoidStateType.Jumping)
                end
            end
        end
        if Camera.FieldOfView ~= CameraFOV then Camera.FieldOfView = CameraFOV end

        if CFrameMoveEnabled then
            local hrp = char:FindFirstChild("HumanoidRootPart")
            if hrp then
                local move = Vector3.zero
                if UIS:IsKeyDown(Enum.KeyCode.W)         then move += Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.S)         then move -= Camera.CFrame.LookVector end
                if UIS:IsKeyDown(Enum.KeyCode.A)         then move -= Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.D)         then move += Camera.CFrame.RightVector end
                if UIS:IsKeyDown(Enum.KeyCode.Space)     then move += Vector3.new(0,1,0) end
                if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then move -= Vector3.new(0,1,0) end
                if move.Magnitude > 0 then
                    hrp.CFrame = hrp.CFrame + move.Unit * CFrameWalkSpeed * (1/60)
                end
            end
        end
    end

    -- Hitbox expander: resize HumanoidRootPart on all enemies
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local hrp = p.Character:FindFirstChild("HumanoidRootPart")
            if hrp then
                if HitboxEnabled then
                    hrp.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
                    hrp.Transparency = 1
                else
                    -- Restore default (don't touch if we never changed it)
                    if hrp:GetAttribute("_marsHitbox") then
                        hrp.Size = Vector3.new(2, 2, 1)
                        hrp:SetAttribute("_marsHitbox", nil)
                    end
                end
                if HitboxEnabled then hrp:SetAttribute("_marsHitbox", true) end
            end

            -- Hitbox visualizer: SelectionBox on HumanoidRootPart
            if HitboxVisualEnabled then
                if not HitboxParts[p] then
                    local sb = Instance.new("SelectionBox")
                    sb.Color3 = Theme.Accent
                    sb.LineThickness = 0.04
                    sb.SurfaceTransparency = 0.8
                    sb.SurfaceColor3 = Theme.Accent
                    sb.Parent = workspace
                    HitboxParts[p] = sb
                end
                local hrp2 = p.Character:FindFirstChild("HumanoidRootPart")
                HitboxParts[p].Adornee = hrp2
            else
                if HitboxParts[p] then
                    HitboxParts[p]:Destroy()
                    HitboxParts[p] = nil
                end
            end
        else
            if HitboxParts[p] then
                HitboxParts[p]:Destroy()
                HitboxParts[p] = nil
            end
        end
    end
end)

