                    end
                end
            end
        end
    end
end)

-- Movement / Character mods
on(RS.Heartbeat,function()
    if Unloaded then return end
    local char=LP.Character; if not char then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if hum then
        if WSOn     then hum.WalkSpeed=WalkSpd end
        if JPOn     then hum.JumpPower=JumpPwr  end
        if InfJumpOn and UIS:IsKeyDown(Enum.KeyCode.Space) then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
    if FOVOn then Camera.FieldOfView=CamFOV end
    if CFMoveOn then
        local hrp=char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local mv=Vector3.zero
            if UIS:IsKeyDown(Enum.KeyCode.W)         then mv=mv+Camera.CFrame.LookVector  end
            if UIS:IsKeyDown(Enum.KeyCode.S)         then mv=mv-Camera.CFrame.LookVector  end
            if UIS:IsKeyDown(Enum.KeyCode.A)         then mv=mv-Camera.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.D)         then mv=mv+Camera.CFrame.RightVector end
            if UIS:IsKeyDown(Enum.KeyCode.Space)     then mv=mv+Vector3.new(0,1,0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then mv=mv-Vector3.new(0,1,0) end
            if mv.Magnitude>0 then hrp.CFrame=hrp.CFrame+mv.Unit*CFSpd*(1/60) end
        end
    end
end)

-- ESP + Radar
on(RS.RenderStepped,function()
    if Unloaded then return end
    local ec = RainbowOn and Color3.fromHSV(RainH,1,1) or C.Accent
    local vp = Camera.ViewportSize
    local cx = vp.X/2
    local cy = vp.Y  -- tracers from screen bottom-center

    for _,p in ipairs(Players:GetPlayers()) do
        if p==LP then continue end
        local char  = p.Character
        local show  = char and isAlive(char) and isEnemy(p)

        if not show then
            if BoneLines[p]    then hideLines(BoneLines[p]) end
            if TracerLines[p]  then hideLine(TracerLines[p]) end
            if BoxLines[p]     then hideLines(BoxLines[p]) end
            if HBLines[p]      then hideHB(HBLines[p]) end
            continue
        end

        local hum  = char:FindFirstChildOfClass("Humanoid")
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end

        -- Bones
        if BoneOn and hum then
            local rig = hum.RigType==Enum.HumanoidRigType.R6 and BONES_R6 or BONES_R15
            BoneLines[p] = BoneLines[p] or {}
            for i,pair in ipairs(rig) do
                local pa=char:FindFirstChild(pair[1])
                local pb=char:FindFirstChild(pair[2])
                if pa and pb then
                    local sp,sv=Camera:WorldToViewportPoint(pa.Position)
                    local ep,ev=Camera:WorldToViewportPoint(pb.Position)
                    if not BoneLines[p][i] then BoneLines[p][i]=newLine(1.5) end
                    local ln=BoneLines[p][i]
                    if ln then
                        if sv and ev then
                            ln.From=Vector2.new(sp.X,sp.Y); ln.To=Vector2.new(ep.X,ep.Y)
                            ln.Color=ec; ln.Visible=true
                        else ln.Visible=false end
                    end
                end
            end
        else hideLines(BoneLines[p]) end

        -- Tracers
        if TracerOn then
            local rp,rv=Camera:WorldToViewportPoint(root.Position)
            if not TracerLines[p] then TracerLines[p]=newLine(1.2) end
            local tr=TracerLines[p]
            if tr then
                if rv then
                    tr.From=Vector2.new(cx,cy); tr.To=Vector2.new(rp.X,rp.Y)
                    tr.Color=ec; tr.Visible=true
                else tr.Visible=false end
            end
        else hideLine(TracerLines[p]) end

        -- Box
        if BoxOn and hum then
            local minX,minY,maxX,maxY=charBounds(char)
            if not BoxLines[p] then BoxLines[p]={newLine(1.5),newLine(1.5),newLine(1.5),newLine(1.5)} end
            local ls=BoxLines[p]
            if minX and ls then
                local tl=Vector2.new(minX,minY); local tr2=Vector2.new(maxX,minY)
                local br=Vector2.new(maxX,maxY); local bl=Vector2.new(minX,maxY)
                if ls[1] then ls[1].From=tl;  ls[1].To=tr2; ls[1].Color=ec; ls[1].Visible=true end
                if ls[2] then ls[2].From=tr2; ls[2].To=br;  ls[2].Color=ec; ls[2].Visible=true end
                if ls[3] then ls[3].From=br;  ls[3].To=bl;  ls[3].Color=ec; ls[3].Visible=true end
                if ls[4] then ls[4].From=bl;  ls[4].To=tl;  ls[4].Color=ec; ls[4].Visible=true end
                -- Health bar
                if HBarOn then
                    if not HBLines[p] then
                        local bg=newLine(4);   if bg   then bg.Color=C3(10,10,10) end
                        local fl=newLine(3)
                        HBLines[p]={bg=bg,fill=fl}
                    end
                    local hb=HBLines[p]
                    local hp=hum and math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1) or 0
                    local hpCol=hp>0.6 and C.Green or hp>0.3 and C.Yellow or C.Red
                    local bx=minX-5
                    if hb.bg   then hb.bg.From=Vector2.new(bx,minY);             hb.bg.To=Vector2.new(bx,maxY); hb.bg.Visible=true end
                    if hb.fill then hb.fill.From=Vector2.new(bx,maxY-(maxY-minY)*hp); hb.fill.To=Vector2.new(bx,maxY); hb.fill.Color=hpCol; hb.fill.Visible=hp>0 end
                else hideHB(HBLines[p]) end
            else
                hideLines(BoxLines[p]); hideHB(HBLines[p])
            end
        else
            hideLines(BoxLines[p]); hideHB(HBLines[p])
        end
    end

    -- Radar
    if RadarOn then
        local mc=LP.Character; local mr=mc and mc:FindFirstChild("HumanoidRootPart")
        local di=0
        if mr then
            local mp=mr.Position
            local fwd=Vector3.new(mr.CFrame.LookVector.X,0,mr.CFrame.LookVector.Z).Unit
            local rgt=Vector3.new(fwd.Z,0,-fwd.X)
            local half=RSIZ/2; local sc2=(half-6)/RadarRange
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=LP and p.Character and isAlive(p.Character) then
                    local tr=p.Character:FindFirstChild("HumanoidRootPart")
                    if tr then
                        local diff=tr.Position-mp
                        if diff.Magnitude<=RadarRange then
                            di+=1; local dot=getRDot(di)
                            local flat=Vector3.new(diff.X,0,diff.Z)
                            dot.Position=UDim2.fromOffset(
                                math.clamp(half+flat:Dot(rgt)*sc2,6,RSIZ-6),
                                math.clamp(half-flat:Dot(fwd)*sc2,6,RSIZ-6))
                            dot.BackgroundColor3=isEnemy(p) and C.RadarE or C.RadarS
                            dot.Visible=true
                        end
                    end
                end
            end
        end
        for i=di+1,#RDots do RDots[i].Visible=false end
    end
end)

