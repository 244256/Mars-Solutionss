-- Checkbox toggle  (square checkbox + animated fill + label)
local function Checkbox(parent, text, default, callback, order)
    local row = Instance.new("Frame", parent)
    row.Size             = UDim2.new(1, 0, 0, 28)
    row.BackgroundTransparency = 1
    if order then row.LayoutOrder = order end

    local box = Instance.new("Frame", row)
    box.Size             = UDim2.fromOffset(16, 16)
    box.Position         = UDim2.new(0, 0, 0.5, 0)
    box.AnchorPoint      = Vector2.new(0, 0.5)
    box.BackgroundColor3 = Theme.Input
    box.BorderSizePixel  = 0
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 4)

    local boxStroke = Instance.new("UIStroke", box)
    boxStroke.Color = Theme.TextDim; boxStroke.Thickness = 1

    local fill = Instance.new("Frame", box)
    fill.Size             = UDim2.fromOffset(0, 0)
    fill.AnchorPoint      = Vector2.new(0.5, 0.5)
    fill.Position         = UDim2.new(0.5, 0, 0.5, 0)
    fill.BackgroundColor3 = Theme.Accent
    fill.BorderSizePixel  = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)

    local lbl = Instance.new("TextLabel", row)
    lbl.Size               = UDim2.new(1, -26, 1, 0)
    lbl.Position           = UDim2.fromOffset(24, 0)
    lbl.BackgroundTransparency = 1
    lbl.Font               = Enum.Font.Gotham
    lbl.TextSize           = 12
    lbl.TextXAlignment     = Enum.TextXAlignment.Left

    local state = default

    local function render()
        if state then
            tween(fill,      { Size = UDim2.fromOffset(10, 10) }, 0.12)
            tween(boxStroke, { Color = Theme.Accent },             0.12)
            tween(lbl,       { TextColor3 = Theme.TextPrimary },   0.12)
        else
            tween(fill,      { Size = UDim2.fromOffset(0, 0) },    0.12)
            tween(boxStroke, { Color = Theme.TextDim },             0.12)
            tween(lbl,       { TextColor3 = Theme.TextSecond },    0.12)
        end
        lbl.Text = text
    end
    render()

    local click = Instance.new("TextButton", row)
    click.Size = UDim2.new(1, 0, 1, 0); click.BackgroundTransparency = 1; click.Text = ""
    connect(click.MouseButton1Click, function()
        state = not state; render(); callback(state)
    end)

    -- Return setter
    return function(v) state = v; render() end
end

-- Keybind badge  (pill showing bound key, click to rebind)
local function KeybindBadge(parent, defaultKey)
    local badge = Instance.new("TextButton", parent)
    badge.Size             = UDim2.fromOffset(58, 20)
    badge.Position         = UDim2.new(1, -58, 0.5, 0)
    badge.AnchorPoint      = Vector2.new(0, 0.5)
    badge.BackgroundColor3 = Theme.AccentDim
    badge.Font             = Enum.Font.GothamBold
    badge.TextSize         = 10
    badge.TextColor3       = Theme.TextPrimary
    badge.Text             = defaultKey and tostring(defaultKey) or "none"
    badge.BorderSizePixel  = 0
    Instance.new("UICorner", badge).CornerRadius = UDim.new(1, 0)

    local listening = false
    connect(badge.MouseButton1Click, function()
        if listening then return end
        listening = true
        badge.Text = "..."
        tween(badge, { BackgroundColor3 = Theme.Accent }, 0.1)
        local conn
        conn = UIS.InputBegan:Connect(function(i, gp)
            if gp then return end
            if i.UserInputType == Enum.UserInputType.Keyboard then
                badge.Text = tostring(i.KeyCode):gsub("Enum.KeyCode.", "")
                tween(badge, { BackgroundColor3 = Theme.AccentDim }, 0.1)
                listening = false
                conn:Disconnect()
            end
        end)
    end)

    return badge
end

-- Slider  (label left, value right-aligned, track below)
local function Slider(parent, text, min, max, default, step, callback, order)
    step = step or 1
    local h = Instance.new("Frame", parent)
    h.Size             = UDim2.new(1, 0, 0, 46)
    h.BackgroundTransparency = 1
    if order then h.LayoutOrder = order end

    local topRow = Instance.new("Frame", h)
    topRow.Size             = UDim2.new(1, 0, 0, 18)
    topRow.BackgroundTransparency = 1

    local lbl = Instance.new("TextLabel", topRow)
    lbl.Size               = UDim2.new(0.6, 0, 1, 0)
    lbl.BackgroundTransparency = 1; lbl.Font = Enum.Font.Gotham
    lbl.TextSize           = 12; lbl.TextColor3 = Theme.TextSecond
    lbl.TextXAlignment     = Enum.TextXAlignment.Left; lbl.Text = text

    local valLbl = Instance.new("TextLabel", topRow)
    valLbl.Size               = UDim2.new(0.4, 0, 1, 0)
    valLbl.Position           = UDim2.new(0.6, 0, 0, 0)
    valLbl.BackgroundTransparency = 1; valLbl.Font = Enum.Font.GothamBold
    valLbl.TextSize           = 12; valLbl.TextColor3 = Theme.TextPrimary
    valLbl.TextXAlignment     = Enum.TextXAlignment.Right
    valLbl.Text               = tostring(default)

    local track = Instance.new("Frame", h)
    track.Position         = UDim2.new(0, 0, 0, 26)
    track.Size             = UDim2.new(1, 0, 0, 6)
    track.BackgroundColor3 = Theme.Input; track.BorderSizePixel = 0
    Instance.new("UICorner", track).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame", track)
    fill.Size             = UDim2.new((default - min)/(max - min), 0, 1, 0)
    fill.BackgroundColor3 = Theme.Accent; fill.BorderSizePixel = 0
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)

    -- Thumb
    local thumb = Instance.new("Frame", track)
    thumb.Size             = UDim2.fromOffset(12, 12)
    thumb.AnchorPoint      = Vector2.new(0.5, 0.5)
    thumb.Position         = UDim2.new((default - min)/(max - min), 0, 0.5, 0)
    thumb.BackgroundColor3 = Theme.TextPrimary; thumb.BorderSizePixel = 0
    Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)

    callback(default)

    local dragging = false
    connect(track.InputBegan, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
    end)
    connect(UIS.InputEnded, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = false
            tween(thumb, { Size = UDim2.fromOffset(12, 12) }, 0.1)
        end
    end)
    connect(RunService.RenderStepped, function()
        if Unloaded or not dragging then return end
        tween(thumb, { Size = UDim2.fromOffset(14, 14) }, 0.08)
        local pct = math.clamp((UIS:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local raw = min + (max - min) * pct
        local val = math.floor(raw / step + 0.5) * step
        local snapped = math.clamp(val, min, max)
        local snappedPct = (snapped - min) / (max - min)
        fill.Size  = UDim2.new(snappedPct, 0, 1, 0)
        thumb.Position = UDim2.new(snappedPct, 0, 0.5, 0)
        valLbl.Text = tostring(snapped)
        callback(snapped)
    end)
end

-- Dropdown
-- dropList is parented to ScreenGui so it always renders above scroll frames
local function Dropdown(parent, text, options, defaultIndex, callback, order)
    local container = Instance.new("Frame", parent)
    container.Size             = UDim2.new(1, 0, 0, 46)
    container.BackgroundTransparency = 1
    container.ClipsDescendants = false
    if order then container.LayoutOrder = order end

    local lbl = Instance.new("TextLabel", container)
    lbl.Size               = UDim2.new(1, 0, 0, 16)
    lbl.BackgroundTransparency = 1; lbl.Font = Enum.Font.Gotham
    lbl.TextSize           = 12; lbl.TextColor3 = Theme.TextSecond
    lbl.TextXAlignment     = Enum.TextXAlignment.Left; lbl.Text = text

    local btn = Instance.new("TextButton", container)
    btn.Size             = UDim2.new(1, 0, 0, 26)
    btn.Position         = UDim2.fromOffset(0, 18)
    btn.BackgroundColor3 = Theme.Input; btn.BorderSizePixel = 0
    btn.Font             = Enum.Font.Gotham; btn.TextSize = 12
    btn.TextColor3       = Theme.TextPrimary; btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 7)

    local btnPad = Instance.new("UIPadding", btn)
    btnPad.PaddingLeft = UDim.new(0, 10)

    local chevron = Instance.new("TextLabel", btn)
    chevron.Size               = UDim2.fromOffset(20, 26)
    chevron.Position           = UDim2.new(1, -24, 0, 0)
    chevron.BackgroundTransparency = 1; chevron.Font = Enum.Font.GothamBold
    chevron.TextSize           = 11; chevron.TextColor3 = Theme.TextDim; chevron.Text = "▾"

    local idx = defaultIndex
    btn.Text = options[idx]
    callback(idx)

    local itemCount = #options
    local listH = itemCount * 30 + 8

    -- Dropdown list parented to Main (above PageContainer in ZIndex, no clip issues)
    local dropList = Instance.new("Frame", Main)
    dropList.Size             = UDim2.fromOffset(0, 0)
    dropList.BackgroundColor3 = Theme.Card
    dropList.BorderSizePixel  = 0
    dropList.ClipsDescendants = true
    dropList.ZIndex           = 50
    dropList.Visible          = false
    Instance.new("UICorner", dropList).CornerRadius = UDim.new(0, 7)

    local dropStroke = Instance.new("UIStroke", dropList)
    dropStroke.Color = Theme.Border; dropStroke.Thickness = 1; dropStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

    local dropLayout = Instance.new("UIListLayout", dropList)
    dropLayout.Padding = UDim.new(0, 2); dropLayout.SortOrder = Enum.SortOrder.LayoutOrder
    local dropPad = Instance.new("UIPadding", dropList)
    dropPad.PaddingTop = UDim.new(0, 4); dropPad.PaddingBottom = UDim.new(0, 4)
    dropPad.PaddingLeft = UDim.new(0, 4); dropPad.PaddingRight = UDim.new(0, 4)

    local open = false

    local function closeDropdown()
        tween(dropList, {Size = UDim2.fromOffset(dropList.AbsoluteSize.X, 0)}, 0.14)
        task.delay(0.14, function() dropList.Visible = false end)
        tween(chevron, {Rotation = 0}, 0.14)
        open = false
    end

    for i, opt in ipairs(options) do
        local item = Instance.new("TextButton", dropList)
        item.LayoutOrder       = i
        item.Size              = UDim2.new(1, 0, 0, 26)
        item.BackgroundColor3  = Theme.Button
        item.Font              = Enum.Font.Gotham; item.TextSize = 12
        item.TextColor3        = i == idx and Theme.TextAccent or Theme.TextSecond
        item.TextXAlignment    = Enum.TextXAlignment.Left; item.Text = opt
        item.BorderSizePixel   = 0; item.ZIndex = 51
        Instance.new("UICorner", item).CornerRadius = UDim.new(0, 6)
        local ip = Instance.new("UIPadding", item); ip.PaddingLeft = UDim.new(0, 8)

        connect(item.MouseEnter, function() tween(item, {BackgroundColor3 = Theme.ButtonHover}, 0.1) end)
        connect(item.MouseLeave, function() tween(item, {BackgroundColor3 = Theme.Button},      0.1) end)
        connect(item.MouseButton1Click, function()
            idx = i; btn.Text = opt; callback(i)
            for _, child in ipairs(dropList:GetChildren()) do
                if child:IsA("TextButton") then
                    child.TextColor3 = child.Text == opt and Theme.TextAccent or Theme.TextSecond
                end
            end
            closeDropdown()
        end)
    end

    connect(btn.MouseButton1Click, function()
        open = not open
        if open then
            -- Read screen position each time (handles window moves)
            local ap  = btn.AbsolutePosition
            local as  = btn.AbsoluteSize
            local mp  = Main.AbsolutePosition
            local w   = as.X
            -- Position relative to Main so it stays inside Main's coordinate space
            local relX = ap.X - mp.X
            local relY = ap.Y - mp.Y + as.Y + 2
            dropList.Size     = UDim2.fromOffset(w, 0)
            dropList.Position = UDim2.fromOffset(relX, relY)
            dropList.Visible  = true
            tween(dropList, {Size = UDim2.fromOffset(w, listH)}, 0.16)
            tween(chevron,  {Rotation = 180},                    0.16)
        else
            closeDropdown()
        end
    end)

    -- Close if window moves (reposition) or user clicks elsewhere
    connect(UIS.InputBegan, function(i, gp)
        if open and i.UserInputType == Enum.UserInputType.MouseButton1 then
            -- small delay so the btn click registers first
            task.defer(function()
                local mp = UIS:GetMouseLocation()
                local dp = dropList.AbsolutePosition
                local ds = dropList.AbsoluteSize
                local inDrop = mp.X >= dp.X and mp.X <= dp.X + ds.X
                            and mp.Y >= dp.Y and mp.Y <= dp.Y + ds.Y
                local bp = btn.AbsolutePosition
                local bs = btn.AbsoluteSize
                local inBtn  = mp.X >= bp.X and mp.X <= bp.X + bs.X
                            and mp.Y >= bp.Y and mp.Y <= bp.Y + bs.Y
                if not inDrop and not inBtn then closeDropdown() end
            end)
        end
    end)
end

-- Sub-tab bar  (thin text row, active = accent + underline)
local function SubTabBar(parent, tabs, order)
    local bar = Instance.new("Frame", parent)
    bar.Size             = UDim2.new(1, 0, 0, 28)
    bar.BackgroundColor3 = Theme.BGSecondary
    bar.BorderSizePixel  = 0
    if order then bar.LayoutOrder = order end
    Instance.new("UICorner", bar).CornerRadius = UDim.new(0, 8)

    local layout = Instance.new("UIListLayout", bar)
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.SortOrder     = Enum.SortOrder.LayoutOrder
    layout.Padding       = UDim.new(0, 0)

    local subUnderline = Instance.new("Frame", bar)
    subUnderline.Size             = UDim2.fromOffset(0, 2)
    subUnderline.Position         = UDim2.new(0, 0, 1, -2)
    subUnderline.BackgroundColor3 = Theme.Accent
    subUnderline.BorderSizePixel  = 0; subUnderline.ZIndex = 3
    Instance.new("UICorner", subUnderline).CornerRadius = UDim.new(1, 0)

    local subPages = {}
    local subBtns  = {}
    local activeSubPage = nil

    local function switchSub(name)
        for n, p in pairs(subPages) do p.Visible = n == name end
        for n, b in pairs(subBtns)  do
            tween(b, {TextColor3 = n == name and Theme.TextPrimary or Theme.TextDim}, 0.12)
        end
        local b = subBtns[name]
        tween(subUnderline, {
            Position = UDim2.new(0, b.AbsolutePosition.X - bar.AbsolutePosition.X, 1, -2),
            Size     = UDim2.fromOffset(b.AbsoluteSize.X, 2)
        }, 0.14)
        activeSubPage = name
    end

    local pageContainer = Instance.new("Frame", parent)
    pageContainer.Size             = UDim2.new(1, 0, 0, 0)
    pageContainer.AutomaticSize   = Enum.AutomaticSize.Y
    pageContainer.BackgroundTransparency = 1
    if order then pageContainer.LayoutOrder = order + 1 end

    for i, tabName in ipairs(tabs) do
        local btn = Instance.new("TextButton", bar)
        btn.LayoutOrder        = i
        btn.Size               = UDim2.new(0, 80, 1, 0)
        btn.BackgroundTransparency = 1
        btn.Text               = tabName
        btn.Font               = Enum.Font.GothamMedium
        btn.TextSize           = 11
        btn.TextColor3         = Theme.TextDim
        btn.BorderSizePixel    = 0
        subBtns[tabName] = btn

        local page = Instance.new("ScrollingFrame", pageContainer)
        page.Size             = UDim2.new(1, 0, 0, 0)
        page.AutomaticSize   = Enum.AutomaticSize.Y
        page.BackgroundTransparency = 1
        page.Visible          = false
        page.BorderSizePixel  = 0
        hideScrollBar(page)
        local pl = Instance.new("UIListLayout", page)
        pl.Padding = UDim.new(0, 6); pl.SortOrder = Enum.SortOrder.LayoutOrder
        local pp = Instance.new("UIPadding", page)
        pp.PaddingLeft  = UDim.new(0, 2)
        pp.PaddingRight = UDim.new(0, 2)
        pp.PaddingTop = UDim.new(0, 4); pp.PaddingBottom = UDim.new(0, 6)
        subPages[tabName] = page

        connect(btn.MouseButton1Click, function() switchSub(tabName) end)
    end

    -- Default to first
    task.defer(function()
        switchSub(tabs[1])
    end)

    return subPages
end

