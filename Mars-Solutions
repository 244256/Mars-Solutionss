-- Silent Aim
local function silentTarget()
    local ctr = Camera.ViewportSize/2
    local best,bd = nil, SilentFOV
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LP and p.Character and isAlive(p.Character) then
            if SilentTeam and not isEnemy(p) then continue end
            local part = p.Character:FindFirstChild("Head") or p.Character:FindFirstChild("HumanoidRootPart")
            if part then
                if SilentVis and not rayVis(part, LP.Character) then continue end
                local sp,sv = Camera:WorldToViewportPoint(part.Position)
                if sv then
                    local d=(Vector2.new(sp.X,sp.Y)-ctr).Magnitude
                    if d<bd then bd=d; best=part end
                end
            end
        end
    end
    return best
end
local function hookSilent()
    if SAHooked then return end
    pcall(function()
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        SAOld = old
        setreadonly(mt,false)
        mt.__namecall = newcclosure(function(self,...)
            local m = getnamecallmethod()
            if SilentOn and (m=="FireServer" or m=="InvokeServer") then
                local tgt = silentTarget()
                if tgt then
                    local save = Camera.CFrame
                    Camera.CFrame = CFrame.new(Camera.CFrame.Position, tgt.Position)
                    local res = {old(self,...)}
                    Camera.CFrame = save
                    return table.unpack(res)
                end
            end
            return old(self,...)
        end)
        setreadonly(mt,true)
    end)
    SAHooked = true
end
local function unhookSilent()
    if not SAHooked then return end
    pcall(function()
        if SAOld then
            local mt = getrawmetatable(game)
            setreadonly(mt,false)
            mt.__namecall = SAOld
            setreadonly(mt,true)
            SAOld = nil
        end
    end)
    SAHooked = false
end

