        -- Auto-scroll to bottom
        logScroll.CanvasPosition = Vector2.new(0, math.max(0, logLayout.AbsoluteContentSize.Y - logScroll.AbsoluteSize.Y + 8))
    end)

    local function appendLog(msg)
        local s = math.floor(tick() - SessionStart)
        local timeStr = string.format("[%02d:%02d]", math.floor(s/60), s%60)
        local row = Instance.new("TextLabel", logScroll)
